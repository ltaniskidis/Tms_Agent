@page
@model Tms.CentralManagement.Pages.ClientsModel
@{
    ViewData["Title"] = "Διαχείριση Πελατών";

    string GetProfileDbName(Tms.CentralManagement.Data.ClientProfile p)
    {
        if (p.ConnectionStringType == "Builder")
        {
            return !string.IsNullOrWhiteSpace(p.DbName) ? p.DbName : "Builder";
        }
        else if (p.ConnectionStringType == "ConfigFile")
        {
            return "Config File";
        }
        else // Direct
        {
            if (string.IsNullOrWhiteSpace(p.ConnectionString)) return "";
            var connStr = p.ConnectionString;
            var match = System.Text.RegularExpressions.Regex.Match(connStr, @"(?:Database|Initial\s+Catalog|Db)\s*=\s*([^;]+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            return match.Success ? match.Groups[1].Value.Trim() : "Direct Conn";
        }
    }

    // Calculate statistics
    var totalMachines = Model.Clients?.Count ?? 0;
    var totalCompanies = Model.Clients == null ? 0 : Model.Clients
        .SelectMany(c => c.Profiles?.Where(p => !p.IsPendingDelete) ?? Enumerable.Empty<ClientProfile>())
        .Select(p => string.IsNullOrWhiteSpace(p.Afm) ? (p.ProfileName?.ToLower().Trim() ?? "") : p.Afm.Trim())
        .Where(x => !string.IsNullOrEmpty(x))
        .Distinct()
        .Count();
    var totalAppUsers = Model.Clients == null ? 0 : Model.Clients.SelectMany(c => c.Profiles?.Where(p => !p.IsPendingDelete) ?? Enumerable.Empty<ClientProfile>()).Sum(p => p.ActiveUsersCount);
    var totalAgentUsers = Model.Clients == null ? 0 : Model.Clients.SelectMany(c => c.LocalUsers ?? Enumerable.Empty<AgentUser>()).Count();
}

<div class="clients-container">
    @Html.AntiForgeryToken()
    <div class="header-section">
        <h1>👥 Διαχείριση Πελατών & Ασφάλειας</h1>
        <p class="subtitle">Αναζητήστε πελάτες, διαχειριστείτε API Keys, δικαιώματα και τοπικούς χρήστες.</p>
    </div>

    <!-- Stats Panel -->
    <div class="stats-panel">
        <div class="stat-card">
            <div class="stat-icon">🖥️</div>
            <div class="stat-info">
                <span class="stat-value">@totalMachines</span>
                <span class="stat-label">Μηχανήματα (Agents)</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🏢</div>
            <div class="stat-info">
                <span class="stat-value">@totalCompanies</span>
                <span class="stat-label">Μοναδικές Εταιρείες</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">💻</div>
            <div class="stat-info">
                <span class="stat-value">@totalAppUsers</span>
                <span class="stat-label">Χρήστες ERP</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">👤</div>
            <div class="stat-info">
                <span class="stat-value">@totalAgentUsers</span>
                <span class="stat-label">Χρήστες Agent</span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <span>✅</span> @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <span>⚠️</span> @Model.ErrorMessage
        </div>
    }

    <!-- Main Tab Navigation -->
    <div class="main-tabs">
        <button class="tab-btn active" onclick="switchPageTab('pageTabCustomers')">👥 Πελάτες &amp; Μηχανήματα</button>
        <button class="tab-btn" onclick="switchPageTab('pageTabAllMachines')">🖥️ Όλα τα Μηχανήματα</button>
    </div>

    <!-- TAB 1: Customers Centric View -->
    <div id="pageTabCustomers" class="page-tab-content">
        <!-- Create Customer Section -->
        <div class="card create-card" style="margin-bottom: 25px;">
            <div class="card-title">➕ Δημιουργία Νέου Πελάτη</div>
            <form method="post" asp-page-handler="CreateCustomer" class="create-form" style="display: flex; gap: 15px; align-items: flex-end;">
                <div class="form-group flex-1" style="margin-bottom: 0;">
                    <label>Όνομα Πελάτη</label>
                    <input type="text" name="name" class="form-control" placeholder="π.χ. ΦΛΕΣΣΑΣ" required />
                </div>
                <div class="form-group flex-1" style="margin-bottom: 0;">
                    <label>Σημειώσεις / Περιγραφή</label>
                    <input type="text" name="notes" class="form-control" placeholder="π.χ. Κεντρικά γραφεία και υποκαταστήματα" />
                </div>
                <button type="submit" class="btn btn-add" style="margin-bottom: 0; padding: 10px 20px; height: 38px; display: flex; align-items: center; justify-content: center;">
                    <span>⚡</span> Δημιουργία
                </button>
            </form>
        </div>

        <!-- Search Bar -->
        <div style="margin-bottom: 20px; position: relative; box-sizing: border-box; width: 100%;">
            <input type="text" id="customer-search-input" onkeyup="filterCustomers()" placeholder="Αναζήτηση πελάτη, σημειώσεων, μηχανήματος (PC Name, Alias, API Key)..." 
                   style="width: 100%; padding: 10px 15px 10px 38px; background-color: #12121A; border: 1px solid var(--border-color); border-radius: 8px; color: var(--text-primary); font-size: 13px; outline: none; transition: border-color 0.2s; box-sizing: border-box;" 
                   onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border-color)'" />
            <span style="position: absolute; left: 14px; top: 12px; color: var(--text-secondary); pointer-events: none; font-size: 14px;">🔍</span>
        </div>

        <!-- Customers Grid -->
        <div class="customer-grid">
            @if (Model.Customers == null || !Model.Customers.Any())
            {
                <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-secondary);">
                    Δεν υπάρχουν καταχωρημένοι πελάτες. Δημιουργήστε έναν παραπάνω.
                </div>
            }
            else
            {
                @foreach (var customer in Model.Customers ?? new List<Customer>())
                {
                    <div class="customer-card">
                        <div class="customer-header">
                            <div class="customer-title">
                                🏢 @customer.Name
                            </div>
                            <div style="display: flex; gap: 6px; align-items: center;">
                                <button type="button" class="btn btn-mini" style="background: none; border: none; color: var(--accent); padding: 4px; font-size: 14px; cursor: pointer;" 
                                        data-id="@customer.Id"
                                        data-name="@customer.Name"
                                        data-notes="@customer.Notes"
                                        onclick="openEditCustomerModal(this)" title="Επεξεργασία Πελάτη">
                                    ✏️
                                </button>
                                <form method="post" asp-page-handler="DeleteCustomer" onsubmit="return confirm('ΠΡΟΣΟΧΗ: Διαγράφοντας τον πελάτη, όλα τα μηχανήματά του θα αποσυνδεθούν. Είστε σίγουροι ότι θέλετε να συνεχίσετε;');" style="margin: 0;">
                                    <input type="hidden" name="id" value="@customer.Id" />
                                    <button type="submit" class="btn-icon-danger" title="Διαγραφή Πελάτη">🗑️</button>
                                </form>
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrWhiteSpace(customer.Notes))
                        {
                            <div class="customer-notes">@customer.Notes</div>
                        }

                        <!-- Machines List under Customer -->
                        <div>
                            <strong style="font-size: 13px; color: var(--text-secondary); display: block; margin-bottom: 8px;">🖥️ Εγκατεστημένοι Agents (@customer.Machines.Count)</strong>
                            @if (!customer.Machines.Any())
                            {
                                <div style="font-size: 12px; color: var(--text-secondary); font-style: italic; padding: 10px 0;">
                                    Δεν υπάρχουν συνδεδεμένα μηχανήματα. Προσθέστε ένα παρακάτω.
                                </div>
                            }
                            else
                            {
                                <table class="customer-machines-table">
                                    <thead>
                                        <tr>
                                            <th>Θέση (Alias)</th>
                                            <th>Μηχάνημα</th>
                                            <th>API Key</th>
                                            <th>Έκδοση</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var client in customer.Machines)
                                        {
                                            <tr>
                                                <td><strong>@(string.IsNullOrEmpty(client.Alias) ? client.MachineName : client.Alias)</strong></td>
                                                <td>
                                                    <span style="color: var(--text-secondary);">@client.MachineName</span>
                                                    <span class="badge" style="font-size: 9px; padding: 2px 4px; background-color: rgba(255,255,255,0.05);">@client.MachineRole</span>

                                                    @if (client.Profiles != null && client.Profiles.Any())
                                                    {
                                                        <div style="margin-top: 8px; display: flex; flex-direction: column; gap: 4px; border-top: 1px dashed rgba(255,255,255,0.08); padding-top: 6px; max-width: 280px;">
                                                            @foreach (var p in client.Profiles)
                                                            {
                                                                <div style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 4px; padding: 4px 6px; font-size: 10px; line-height: 1.4;" 
                                                                     title="Τελευταίος Συγχρονισμός: @(p.LastUpdatedTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")">
                                                                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 6px; flex-wrap: wrap;">
                                                                        <span style="font-weight: 500; text-align: left;">🏢 @p.ProfileName</span>
                                                                        <span style="display: inline-flex; gap: 3px;">
                                                                            <span style="color: #3B82F6; font-weight: bold; background: rgba(59, 130, 246, 0.1); padding: 0 4px; border-radius: 3px; font-size: 9px;">v@(p.LastUpdatedProgramVersion)</span>
                                                                            <span style="color: var(--text-secondary); background: rgba(255,255,255,0.05); padding: 0 4px; border-radius: 3px; font-size: 9px;">DB: @p.LastUpdatedDbVersion</span>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </td>
                                                <td>
                                                    <code style="background: rgba(0,0,0,0.2); padding: 2px 6px; border-radius: 4px; color: var(--accent); font-family: monospace; font-size: 11px;">@client.ApiKey</code>
                                                    <button type="button" onclick="navigator.clipboard.writeText('@client.ApiKey'); alert('Το API Key αντιγράφηκε!');" class="btn btn-mini" style="padding: 1px 4px; font-size: 10px; margin-left: 4px;" title="Αντιγραφή">📋</button>
                                                </td>
                                                <td>
                                                    @if (client.AgentVersion == Model.CurrentSystemVersion)
                                                    {
                                                        <span class="agent-ver-text" style="color: var(--success); font-weight: bold;" title="Ο Agent είναι συγχρονισμένος με την τρέχουσα έκδοση συστήματος (v@(Model.CurrentSystemVersion)). @(client.LastAgentUpgradeTime.HasValue ? $"Αναβάθμιση: {client.LastAgentUpgradeTime.Value.ToString("dd/MM/yyyy HH:mm")}" : "")">🤖 v@(client.AgentVersion)</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="agent-ver-text" style="color: var(--warning); font-weight: bold; background-color: rgba(245, 158, 11, 0.1); padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(245, 158, 11, 0.3);" title="⚠️ Διαφορά έκδοσης! Η τρέχουσα έκδοση συστήματος είναι v@(Model.CurrentSystemVersion). @(client.LastAgentUpgradeTime.HasValue ? $"Αναβάθμιση: {client.LastAgentUpgradeTime.Value.ToString("dd/MM/yyyy HH:mm")}" : "")">⚠️ v@(client.AgentVersion)</span>
                                                    }
                                                    
                                                    @if (client.LastCommunicationTime.HasValue)
                                                    {
                                                        var timeSinceLastComm = DateTime.UtcNow - client.LastCommunicationTime.Value;
                                                        var isActive = timeSinceLastComm.TotalMinutes <= 5;
                                                        <div style="font-size: 9px; color: @(isActive ? "#10B981" : "var(--text-secondary)"); margin-top: 4px; font-weight: @(isActive ? "bold" : "normal");" title="Τελευταία επικοινωνία: @client.LastCommunicationTime.Value.ToString("dd/MM/yyyy HH:mm:ss")">
                                                            @(isActive ? "🟢 Active" : $"⏳ {client.LastCommunicationTime.Value.ToString("dd/MM/yyyy HH:mm")}")
                                                        </div>
                                                    }
                                                </td>
                                                <td style="white-space: nowrap;">
                                                    <button type="button" class="btn btn-mini btn-action" 
                                                            data-id="@client.Id"
                                                            data-name="@client.MachineName"
                                                            data-role="@client.MachineRole"
                                                            data-guid="@client.ClientGuid"
                                                            data-apikey="@client.ApiKey"
                                                            data-upgrade="@(client.IsUpgradeEnabled ? "true" : "false")"
                                                            data-startwithwindows="@(client.StartWithWindows ? "true" : "false")"
                                                            data-viewlogs="@(client.Permissions?.CanOperatorViewLogs == true ? "true" : "false")"
                                                            data-runupdates="@(client.Permissions?.CanOperatorRunUpdates == true ? "true" : "false")"
                                                            data-users="@System.Text.Json.JsonSerializer.Serialize(client.LocalUsers)"
                                                            data-profiles="@System.Text.Json.JsonSerializer.Serialize(client.Profiles)"
                                                            data-alias="@client.Alias"
                                                            data-customerid="@client.CustomerId"
                                                            onclick="openModalFromBtn(this)">
                                                        ⚙️
                                                    </button>
                                                    <form method="post" asp-page-handler="DeleteClient" onsubmit="return confirm('Είστε σίγουροι ότι θέλετε να διαγράψετε αυτό το μηχάνημα;');" style="display: inline-block; margin: 0; margin-left: 4px;">
                                                        <input type="hidden" name="id" value="@client.Id" />
                                                        <button type="submit" class="btn btn-mini btn-danger-action" title="Διαγραφή">🗑️</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>

                        <!-- Add Machine Form Toggle -->
                        <div style="margin-top: 10px; border-top: 1px dashed var(--border-color); padding-top: 12px;">
                            <button type="button" onclick="toggleAddMachineForm(@customer.Id)" class="btn btn-mini" style="background-color: rgba(59, 130, 246, 0.1); color: #3B82F6; border: 1px solid rgba(59, 130, 246, 0.2); font-weight: 600;">
                                ➕ Προσθήκη Μηχανήματος (Νέο API Key)
                            </button>
                            
                            <div id="addMachineForm_@customer.Id" style="display: none; margin-top: 12px; background-color: rgba(0,0,0,0.15); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px;">
                                <form method="post" asp-page-handler="AddMachineToCustomer" style="display: flex; flex-direction: column; gap: 10px; margin: 0;">
                                    <input type="hidden" name="customerId" value="@customer.Id" />
                                    
                                    <div style="display: flex; gap: 10px;">
                                        <div style="flex: 1;">
                                            <label style="font-size: 11px; color: var(--text-secondary); display: block; margin-bottom: 4px;">Όνομα Μηχανήματος (PC Name)</label>
                                            <input type="text" name="machineName" class="form-control form-control-sm" placeholder="π.χ. FLESSAS-PC4" required />
                                        </div>
                                        <div style="flex: 1;">
                                            <label style="font-size: 11px; color: var(--text-secondary); display: block; margin-bottom: 4px;">Alias / Θέση (π.χ. Λογιστήριο)</label>
                                            <input type="text" name="alias" class="form-control form-control-sm" placeholder="π.χ. PC Λογιστή 3" required />
                                        </div>
                                    </div>
                                    
                                    <div style="margin-top: 2px;">
                                        <label style="font-size: 11px; color: var(--text-secondary); display: block; margin-bottom: 4px;">Connection String Βάσης (Προαιρετικό - π.χ. για VPN / διαφορετικό SQL Server)</label>
                                        <input type="text" name="connectionString" class="form-control form-control-sm" placeholder="Server=10.8.0.1;Database=TIMOLOGISI;User Id=sa;Password=..." />
                                    </div>
                                    
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 5px;">
                                        <div>
                                            <label style="font-size: 11px; color: var(--text-secondary); margin-right: 5px;">Ρόλος:</label>
                                            <select name="machineRole" class="form-control form-control-sm select-control" style="display: inline-block; width: auto; padding: 2px 6px;">
                                                <option value="Both">Both</option>
                                                <option value="Client" selected>Client</option>
                                                <option value="SqlServer">SqlServer</option>
                                            </select>
                                        </div>
                                        <button type="submit" class="btn btn-mini" style="background-color: var(--success); color: white; border: none; font-weight: bold; padding: 4px 12px;">
                                            ⚡ Δημιουργία Key
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- TAB 2: Flat All Machines View -->
    <div id="pageTabAllMachines" class="page-tab-content" style="display: none;">
        <!-- Create Client Section -->
        <div class="card create-card">
            <div class="card-title">➕ Προσθήκη Νέου Μηχανήματος (Client Machine - Flat)</div>
            <form method="post" asp-page-handler="CreateClient" class="create-form">
                <div class="form-group flex-1">
                    <label>Όνομα Μηχανήματος</label>
                    <input type="text" name="machineName" class="form-control" placeholder="π.χ. DESKTOP-OFFICE1" required />
                </div>
                <div class="form-group">
                    <label>Ρόλος Μηχανήματος</label>
                    <select name="machineRole" class="form-control select-control">
                        <option value="Both">Both (SqlServer & Client)</option>
                        <option value="SqlServer">SqlServer Only</option>
                        <option value="Client">Client Only</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-add">
                    <span>⚡</span> Δημιουργία
                </button>
            </form>
        </div>

        <!-- Filters & Table Grid -->
        <div class="card grid-card">
        <div class="grid-header-actions">
            <div class="card-title">🖥️ Ενεργά Μηχανήματα Πελατών (@(Model.Clients?.Count ?? 0))</div>
            
            <!-- Filters Bar -->
            <div class="filters-bar">
                <div class="filter-group">
                    <input type="text" id="searchFilter" onkeyup="applyFilters()" class="form-control search-input" placeholder="🔍 Αναζήτηση (Όνομα, GUID, API Key...)" />
                </div>
                <div class="filter-group">
                    <select id="roleFilter" onchange="applyFilters()" class="form-control select-control filter-select">
                        <option value="All">Όλοι οι Ρόλοι</option>
                        <option value="Both">Both</option>
                        <option value="SqlServer">SqlServer</option>
                        <option value="Client">Client</option>
                    </select>
                </div>
                <div class="filter-group">
                    <select id="upgradeFilter" onchange="applyFilters()" class="form-control select-control filter-select">
                        <option value="All">Όλες οι Αναβαθμίσεις</option>
                        <option value="Enabled">Επιτρέπονται</option>
                        <option value="Disabled">Απαγορεύονται</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Data Table Grid -->
        <div class="table-responsive">
            <table class="clients-table" id="clientsTable">
                <thead>
                    <tr>
                        <th>Μηχάνημα &amp; Ρόλος</th>
                        <th>Συνδεδεμένες Εταιρείες (ΑΦΜ)</th>
                        <th>Βάσεις</th>
                        <th>Χρήστες (Breakdown)</th>
                        <th>API Key &amp; GUID</th>
                        <th>Έκδοση Agent</th>
                        <th>Αναβαθμίσεις</th>
                        <th style="text-align: right;">Ενέργειες</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Clients == null || !Model.Clients.Any())
                    {
                        <tr class="no-data-row">
                            <td colspan="8" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                Δεν υπάρχουν καταχωρημένοι πελάτες.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var client in Model.Clients)
                        {
                            var activeClientProfiles = (client.Profiles ?? new List<ClientProfile>()).Where(p => !p.IsPendingDelete).ToList();
                            var profileNames = string.Join(" ", activeClientProfiles.Select(p => (p.ProfileName ?? "").ToLower()));
                            var profileAfms = string.Join(" ", activeClientProfiles.Select(p => p.Afm ?? ""));
                            var profileSerials = string.Join(" ", activeClientProfiles.Select(p => p.SerialNumber ?? ""));
                            var appUsersSum = activeClientProfiles.Sum(p => p.ActiveUsersCount);
                            
                            <tr class="client-row" 
                                data-name="@client.MachineName.ToLower()" 
                                data-guid="@client.ClientGuid.ToLower()" 
                                data-key="@client.ApiKey.ToLower()" 
                                data-role="@client.MachineRole" 
                                data-upgrade="@(client.IsUpgradeEnabled ? "Enabled" : "Disabled")"
                                data-profiles="@profileNames"
                                data-afms="@profileAfms"
                                data-serials="@profileSerials">
                                
                                <td class="td-name">
                                    <strong>@client.MachineName</strong>
                                    @if (client.StartWithWindows)
                                    {
                                        <span class="badge badge-mini" style="background-color: rgba(59, 130, 246, 0.15); color: #3B82F6; margin-left: 5px; font-size: 10px; font-weight: bold; border-radius: 4px; padding: 2px 5px;" title="Εκκίνηση με τα Windows: Ενεργοποιημένη">🚀 Boot</span>
                                    }
                                    <br />
                                    <span class="badge badge-role badge-@(client.MachineRole.ToLower())">@client.MachineRole</span>
                                </td>
                                <td>
                                    @if (!activeClientProfiles.Any())
                                    {
                                        <span style="color: var(--text-secondary); font-style: italic; font-size: 13px;">Καμία Εταιρεία</span>
                                    }
                                    else
                                    {
                                        <div class="company-list">
                                            @foreach (var profile in activeClientProfiles)
                                            {
                                                <div class="company-item">
                                                    <span class="company-name" title="@profile.ProfileName">🏢 @profile.ProfileName</span>
                                                    <span class="company-afm">(ΑΦΜ: @profile.Afm)</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    @{
                                        var profileDbs = activeClientProfiles
                                            .Select(p => GetProfileDbName(p))
                                            .Where(db => !string.IsNullOrEmpty(db))
                                            .Distinct(StringComparer.OrdinalIgnoreCase)
                                            .ToList();
                                        
                                        var discoveredDbs = client.Databases
                                            .Select(d => d.DatabaseName)
                                            .Where(name => !profileDbs.Contains(name, StringComparer.OrdinalIgnoreCase))
                                            .ToList();
                                    }
                                    @if (!profileDbs.Any() && !discoveredDbs.Any())
                                    {
                                        <span style="color: var(--text-secondary); font-style: italic; font-size: 13px;">Καμία Βάση</span>
                                    }
                                    else
                                    {
                                        <div style="display: flex; flex-direction: column; gap: 4px; align-items: flex-start;">
                                            @foreach (var db in profileDbs)
                                            {
                                                <span class="badge badge-db" style="font-size: 12px; font-weight: bold; background-color: rgba(16, 185, 129, 0.15); color: #10B981; padding: 3px 6px; border-radius: 4px; white-space: nowrap;" title="Συνδεδεμένη Βάση Εταιρείας">
                                                    🔗 @db
                                                </span>
                                            }
                                            @foreach (var db in discoveredDbs)
                                            {
                                                <span class="badge" style="font-size: 11px; background-color: rgba(99, 102, 241, 0.1); color: #818CF8; padding: 2px 5px; border-radius: 4px; white-space: nowrap;" title="Ανιχνευμένη Βάση SQL Server (Agent)">
                                                    🔍 @db
                                                </span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="users-breakdown">
                                        <span class="badge badge-users-agent" title="Τοπικοί Χρήστες Agent">👤 @client.LocalUsers.Count</span>
                                        <span class="badge badge-users-app" title="Ενεργοί Χρήστες ERP">💻 @appUsersSum</span>
                                    </div>
                                </td>
                                <td class="td-key">
                                    <div class="key-container" style="display:flex; flex-direction:column; gap:4px; align-items:flex-start;">
                                        <div class="key-row" style="display:flex; align-items:center; gap:6px;">
                                            <span class="code-text key-display" style="font-size:11px;">@client.ApiKey</span>
                                            <button class="btn btn-copy" onclick="copyText('@client.ApiKey', this)" title="Αντιγραφή API Key">📋</button>
                                        </div>
                                        <span class="code-text" style="font-size: 9px; opacity: 0.6; padding: 1px 4px; border:none; background:none;">GUID: @client.ClientGuid</span>
                                    </div>
                                </td>
                                 <td>
                                     @if (client.AgentVersion == Model.CurrentSystemVersion)
                                     {
                                         <span class="agent-ver-text" style="color: var(--success); font-weight: bold;" title="Ο Agent είναι συγχρονισμένος με την τρέχουσα έκδοση συστήματος (v@(Model.CurrentSystemVersion))">🤖 v@(client.AgentVersion)</span>
                                     }
                                     else
                                     {
                                         <span class="agent-ver-text" style="color: var(--warning); font-weight: bold; background-color: rgba(245, 158, 11, 0.1); padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(245, 158, 11, 0.3);" title="⚠️ Διαφορά έκδοσης! Η τρέχουσα έκδοση συστήματος είναι v@(Model.CurrentSystemVersion)">⚠️ v@(client.AgentVersion)</span>
                                     }
                                 </td>
                                <td>
                                    @if (client.IsUpgradeEnabled)
                                    {
                                        <span class="badge badge-success">🟢 Ναι</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">🔴 Όχι</span>
                                    }
                                </td>
                                <td style="text-align: right; white-space: nowrap;">
                                    <button class="btn btn-mini btn-manage" 
                                            data-id="@client.Id"
                                            data-name="@client.MachineName"
                                            data-role="@client.MachineRole"
                                            data-guid="@client.ClientGuid"
                                            data-apikey="@client.ApiKey"
                                            data-upgrade="@(client.IsUpgradeEnabled ? "true" : "false")"
                                            data-startwithwindows="@(client.StartWithWindows ? "true" : "false")"
                                            data-viewlogs="@(client.Permissions?.CanOperatorViewLogs == true ? "true" : "false")"
                                            data-runupdates="@(client.Permissions?.CanOperatorRunUpdates == true ? "true" : "false")"
                                            data-users="@System.Text.Json.JsonSerializer.Serialize(client.LocalUsers)"
                                            data-profiles="@System.Text.Json.JsonSerializer.Serialize(client.Profiles)"
                                            data-alias="@client.Alias"
                                            data-customerid="@client.CustomerId"
                                            onclick="openModalFromBtn(this)">
                                        ⚙️ Διαχείριση
                                    </button>
                                    
                                    <form method="post" asp-page-handler="DeleteClient" onsubmit="return confirm('Είστε σίγουροι ότι θέλετε να διαγράψετε αυτόν τον πελάτη;');" style="display: inline-block; margin-left: 5px;">
                                        <input type="hidden" name="id" value="@client.Id" />
                                        <button type="submit" class="btn btn-mini btn-danger-action" title="Διαγραφή">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>

<!-- Modal Overlay for Management -->
<div id="manageModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modalTitle">Διαχείριση Πελάτη</h3>
            <span class="close-btn" onclick="closeModal()">×</span>
        </div>
        
        <div class="modal-body">
            <!-- Modal Success/Error Alerts -->
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success" style="margin-bottom: 15px; padding: 8px 12px; font-size: 13px;">
                    <span>✅</span> @Model.SuccessMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" style="margin-bottom: 15px; padding: 8px 12px; font-size: 13px;">
                    <span>⚠️</span> @Model.ErrorMessage
                </div>
            }
            <!-- Details Panel -->
            <div class="modal-section-details">
                <div class="detail-grid">
                    <div>
                        <span class="detail-label">Client GUID</span>
                        <span id="modalGuid" class="detail-value code-text"></span>
                    </div>
                    <div>
                        <span class="detail-label">API Key</span>
                        <div class="modal-key-row">
                            <span id="modalApiKey" class="detail-value code-text key-text"></span>
                            <form method="post" asp-page-handler="RegenerateApiKey" id="modalRegenForm" style="display:inline;">
                                <input type="hidden" name="id" id="modalRegenId" value="" />
                                <button type="submit" class="btn btn-mini" title="Ανανέωση API Key">🔄</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Buttons -->
            <div class="modal-tabs">
                <button class="modal-tab-btn active" id="tabSettingsBtn" onclick="switchModalTab('settings')">⚙️ Ρυθμίσεις & Δικαιώματα</button>
                <button class="modal-tab-btn" id="tabUsersBtn" onclick="switchModalTab('users')">👤 Χρήστες Agent (<span id="modalUsersCount">0</span>)</button>
                <button class="modal-tab-btn" id="tabProfilesBtn" onclick="switchModalTab('profiles')">🏢 Εταιρείες (<span id="modalProfilesCount">0</span>)</button>
            </div>

            <!-- Tab 1: Settings Form -->
            <div class="modal-tab-content" id="tabContentSettings">
                <form method="post" asp-page-handler="UpdateClientSettings" class="modal-form">
                    <input type="hidden" name="id" id="modalSettingsId" value="" />
                    
                    <div class="form-group">
                        <label>Όνομα Μηχανήματος (PC Name)</label>
                        <input type="text" name="machineName" id="modalMachineName" class="form-control" placeholder="π.χ. DESKTOP-OFFICE1" required />
                    </div>

                    <div class="form-group">
                        <label>Alias / Θέση Εργασίας</label>
                        <input type="text" name="alias" id="modalAlias" class="form-control" placeholder="π.χ. PC Λογιστή 3" />
                    </div>

                    <div class="form-group">
                        <label>Αντιστοίχιση σε Πελάτη</label>
                        <select name="customerId" id="modalCustomerId" class="form-control select-control">
                            <option value="">-- Χωρίς Πελάτη --</option>
                            @foreach (var cust in Model.Customers ?? new List<Customer>())
                            {
                                <option value="@cust.Id">@cust.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Ρόλος Μηχανήματος</label>
                        <select name="machineRole" id="modalMachineRole" class="form-control select-control">
                            <option value="Both">Both (SqlServer & Client)</option>
                            <option value="SqlServer">SqlServer Only</option>
                            <option value="Client">Client Only</option>
                        </select>
                    </div>

                    <div class="toggle-group">
                        <label class="toggle-container">
                            <input type="checkbox" name="isUpgradeEnabled" id="modalIsUpgradeEnabled" value="true" />
                            <span class="toggle-slider"></span>
                            <span class="toggle-label">Επιτρέπονται οι Αναβαθμίσεις</span>
                        </label>
                        <div class="toggle-help">Εάν απενεργοποιηθεί, ο Agent θα εμφανίσει μήνυμα επικοινωνίας με τον προμηθευτή.</div>
                    </div>

                    <div class="permissions-group">
                        <label class="checkbox-container">
                            <input type="checkbox" name="startWithWindows" id="modalStartWithWindows" value="true" />
                            <span class="checkbox-checkmark"></span>
                            <span class="checkbox-label">Εκκίνηση με τα Windows (Service / Boot)</span>
                        </label>
                        <label class="checkbox-container" style="margin-top: 10px;">
                            <input type="checkbox" name="canOperatorViewLogs" id="modalCanOperatorViewLogs" value="true" />
                            <span class="checkbox-checkmark"></span>
                            <span class="checkbox-label">Ο Operator μπορεί να βλέπει Logs</span>
                        </label>
                        <label class="checkbox-container">
                            <input type="checkbox" name="canOperatorRunUpdates" id="modalCanOperatorRunUpdates" value="true" />
                            <span class="checkbox-checkmark"></span>
                            <span class="checkbox-label">Ο Operator μπορεί να τρέχει Εγκεκριμένα Updates</span>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-login">💾 Αποθήκευση Ρυθμίσεων</button>
                </form>
            </div>

            <!-- Tab 2: Users Management -->
            <div class="modal-tab-content" id="tabContentUsers" style="display: none;">
                <!-- Current Users List -->
                <div class="modal-users-list-container">
                    <ul class="users-list" id="modalUsersList">
                        <!-- Dynamic list items will be injected here -->
                    </ul>
                    <div id="modalNoUsersMsg" class="no-users-note" style="display: none;">
                        Δεν υπάρχουν τοπικοί χρήστες. (Μόνο Master Owner πρόσβαση)
                    </div>
                </div>

                <hr class="card-divider" style="margin: 15px 0;" />

                <!-- Add User Form -->
                <div class="modal-add-user-section">
                    <div class="card-subtitle" style="font-size:12px;">➕ Προσθήκη Χρήστη Agent</div>
                    <form method="post" asp-page-handler="AddAgentUser" class="add-user-form">
                        <input type="hidden" name="clientMachineId" id="modalAddUserClientId" value="" />
                        <div class="form-row">
                            <input type="text" name="username" class="form-control form-control-sm" placeholder="Username" required />
                            <input type="text" name="password" class="form-control form-control-sm" placeholder="Κωδικός" required />
                            <select name="role" class="form-control form-control-sm select-control">
                                <option value="Operator">Operator</option>
                                <option value="Admin">Admin</option>
                            </select>
                            <button type="submit" class="btn btn-sm-add" title="Προσθήκη Χρήστη">➕</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tab 3: Profiles Management -->
            <div class="modal-tab-content" id="tabContentProfiles" style="display: none;">
                <!-- Current Profiles List -->
                <div class="modal-profiles-list-container" style="margin-bottom: 15px;">
                    <div class="card-subtitle" style="font-size:12px; margin-bottom: 8px;">🏢 Συνδεδεμένες Εταιρείες (<span id="modalProfilesCountText">0</span>)</div>
                    <div id="modalProfilesList" class="profiles-grid-list">
                        <!-- Dynamic profiles will be injected here -->
                    </div>
                    <div id="modalNoProfilesMsg" class="no-users-note" style="display: none;">
                        Δεν υπάρχουν καταχωρημένες εταιρείες για αυτό το μηχάνημα.
                    </div>
                </div>

                <!-- Add/Edit Profile Form Container -->
                <div class="modal-profile-form-section" id="profileFormSection">
                    <div class="card-subtitle" id="profileFormTitle" style="font-size:12px; font-weight: bold; color: var(--accent);">➕ Προσθήκη Νέας Εταιρείας</div>
                    <form method="post" id="profileForm" class="profile-tab-form" style="margin-top: 10px; display: flex; flex-direction: column; gap: 10px;">
                        <input type="hidden" name="clientMachineId" id="profileFormClientId" value="" />
                        <input type="hidden" name="editProfileId" id="profileFormEditId" value="" />

                        <div class="form-row-2col">
                            <div class="form-group-sm" id="profileIdFieldGroup">
                                <label>ID Προφίλ (Λατινικά)</label>
                                <input type="text" name="profileId" id="profileFormProfileId" class="form-control form-control-sm" placeholder="π.χ. ClientA" required />
                            </div>
                            <div class="form-group-sm">
                                <label>Όνομα Εταιρείας</label>
                                <input type="text" name="profileName" id="profileFormProfileName" class="form-control form-control-sm" placeholder="π.χ. Εταιρεία Α.Ε." required />
                            </div>
                        </div>

                        <div class="form-row-2col">
                            <div class="form-group-sm">
                                <label>ΑΦΜ</label>
                                <input type="text" name="afm" id="profileFormAfm" class="form-control form-control-sm" placeholder="ΑΦΜ" />
                            </div>
                            <div class="form-group-sm">
                                <label>Σειριακός Αριθμός</label>
                                <input type="text" name="serialNumber" id="profileFormSerial" class="form-control form-control-sm" placeholder="Αφήστε κενό για αυτόματη δημιουργία" />
                            </div>
                        </div>

                        <div class="form-row-2col">
                            <div class="form-group-sm">
                                <label>Ενεργοί Χρήστες ERP</label>
                                <input type="number" name="activeUsersCount" id="profileFormUsers" class="form-control form-control-sm" value="1" min="0" />
                            </div>
                            <div class="form-group-sm">
                                <label>Όνομα EXE</label>
                                <input type="text" name="targetExeName" id="profileFormExe" class="form-control form-control-sm" value="TIMOLOGISI.exe" />
                            </div>
                        </div>

                        <div class="form-group-sm">
                            <label>Φάκελος Εγκατάστασης</label>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" name="targetFolder" id="profileFormFolder" class="form-control form-control-sm" placeholder="π.χ. C:\Program Files\TmsApp" style="flex: 1;" />
                                <button type="button" class="btn btn-outline btn-sm" onclick="triggerFolderBrowse('profileFormFolder')" style="padding: 0 10px; height: 31px; display: flex; align-items: center; justify-content: center; gap: 4px; font-size: 11px;">📂 Αναζήτηση</button>
                            </div>
                            <input type="file" id="folderBrowserDummy" webkitdirectory directory style="display: none;" onchange="handleFolderSelected(this, 'profileFormFolder')" />
                            
                            <!-- Folder path suggestions due to browser security sandbox -->
                            <div id="folderSuggestions" style="display: none; margin-top: 5px; background-color: #12121A; border: 1px solid #1E1E2C; border-radius: 6px; padding: 10px;">
                                <div style="font-size: 10px; color: var(--text-secondary); margin-bottom: 6px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">💡 Προτεινόμενες Τοπικές Διαδρομές:</div>
                                <div style="display: flex; flex-direction: column; gap: 6px;" id="folderSuggestionsList"></div>
                            </div>
                            
                            <small class="form-text text-muted" style="font-size: 9px; color: var(--text-secondary); margin-top: 2px;">⚠️ Σημείωση: Ο browser εμφανίζει προειδοποίηση «Μεταφόρτωση» για λόγους ασφαλείας. Το σύστημα **δεν ανεβάζει κανένα αρχείο**, απλώς διαβάζει τη διαδρομή. Εναλλακτικά, πληκτρολογήστε τη διαδρομή χειροκίνητα.</small>
                        </div>

                        <!-- Email(s) for notifications -->
                        <div class="form-group-sm">
                            <label>Emails Επικοινωνίας (διαχωρισμένα με κόμμα)</label>
                            <input type="text" name="emails" id="profileFormEmails" class="form-control form-control-sm" placeholder="π.χ. support@company.com, admin@company.com" value="support@cleverdata.gr,l.taniskdis@cleverdata.gr,e.kordouli@cleverdata.gr" />
                        </div>

                        <!-- Connection Configuration Type -->
                        <div class="form-group-sm">
                            <label>Τύπος Σύνδεσης Βάσης</label>
                            <select name="connectionStringType" id="profileFormConnectionStringType" class="form-control form-control-sm" onchange="toggleConnectionStringFields()">
                                <option value="Direct">Απευθείας Connection String</option>
                                <option value="Builder">Κατασκευαστής (Builder)</option>
                                <option value="ConfigFile">Ανάγνωση από Αρχείο Ρυθμίσεων (.config / .json)</option>
                            </select>
                        </div>

                        <!-- Section A: Direct Connection String -->
                        <div id="sectionConnDirect" class="form-group-sm">
                            <label>Connection String SQL Server</label>
                            <input type="text" name="connectionString" id="profileFormConnectionString" class="form-control form-control-sm" placeholder="Connection String" />
                        </div>

                        <!-- Section B: Connection String Builder -->
                        <div id="sectionConnBuilder" style="display: none; border: 1px solid var(--border-color); border-radius: 6px; padding: 10px; margin-bottom: 10px; background-color: rgba(255,255,255,0.02);">
                            <div class="form-group-sm">
                                <label>SQL Server / Instance</label>
                                <input type="text" name="dbServer" id="profileFormDbServer" class="form-control form-control-sm" placeholder="π.χ. localhost\SQLEXPRESS" oninput="compileConnectionStringFromBuilder()" />
                            </div>
                            <div class="form-group-sm">
                                <label>Όνομα Βάσης Δεδομένων</label>
                                <input type="text" name="dbName" id="profileFormDbName" class="form-control form-control-sm" placeholder="π.χ. TmsDb" oninput="compileConnectionStringFromBuilder()" />
                            </div>
                            
                            <div class="form-group-sm" style="margin-top: 5px; margin-bottom: 5px;">
                                <label style="display: flex; align-items: center; gap: 6px; cursor: pointer; font-size: 11px;">
                                    <input type="checkbox" name="dbUseWindowsAuth" id="profileFormDbWindowsAuth" value="true" onchange="toggleWindowsAuthFields(); compileConnectionStringFromBuilder();" />
                                     Windows Authentication (Integrated Security)
                                </label>
                            </div>

                            <div id="builderCredentialsRow" class="form-row-2col">
                                <div class="form-group-sm">
                                    <label>Όνομα Χρήστη</label>
                                    <input type="text" name="dbUser" id="profileFormDbUser" class="form-control form-control-sm" placeholder="sa" oninput="compileConnectionStringFromBuilder()" />
                                </div>
                                <div class="form-group-sm">
                                    <label>Κωδικός Χρήστη</label>
                                    <div style="position: relative; display: flex; align-items: center;">
                                        <input type="password" name="dbPassword" id="profileFormDbPassword" class="form-control form-control-sm" placeholder="password" oninput="compileConnectionStringFromBuilder()" style="padding-right: 32px; width: 100%;" />
                                        <button type="button" id="toggleDbPasswordBtn" onclick="toggleDbPasswordVisibility()" style="position: absolute; right: 8px; background: none; border: none; color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 4px; outline: none; font-size: 13px;" title="Εμφάνιση/Απόκρυψη Κωδικού">👁️</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section C: Configuration File Reader -->
                        <div id="sectionConnConfigFile" style="display: none; border: 1px solid var(--border-color); border-radius: 6px; padding: 10px; margin-bottom: 10px; background-color: rgba(255,255,255,0.02);">
                            <div class="form-group-sm">
                                <label>Διαδρομή Αρχείου Ρυθμίσεων (στον πελάτη)</label>
                                <div style="display: flex; gap: 8px;">
                                    <input type="text" name="configFilePath" id="profileFormConfigPath" class="form-control form-control-sm" placeholder="π.χ. C:\Program Files\TmsApp\appsettings.json" style="flex: 1;" />
                                    <button type="button" class="btn btn-outline btn-sm" onclick="triggerFileBrowse('profileFormConfigPath')" style="padding: 0 10px; height: 31px; display: flex; align-items: center; justify-content: center; gap: 4px; font-size: 11px;">📄 Αναζήτηση</button>
                                </div>
                                <input type="file" id="fileBrowserDummy" accept=".json,.config,.xml" style="display: none;" onchange="handleFileSelected(this, 'profileFormConfigPath')" />
                                <small class="form-text text-muted" style="font-size: 9px; color: var(--text-secondary); margin-top: 2px;">⚠️ Ορίζετε το αρχείο ρυθμίσεων (JSON ή XML) από όπου ο Agent θα διαβάζει αυτόματα τη σύνδεση.</small>
                            </div>
                        </div>

                        <div class="form-actions-row" style="display: flex; gap: 10px; margin-top: 5px;">
                            <button type="submit" id="profileFormSubmitBtn" class="btn btn-login btn-sm" style="flex: 1; padding: 8px;">➕ Προσθήκη Εταιρείας</button>
                            <button type="button" id="profileFormCancelBtn" class="btn btn-outline btn-sm" style="display: none; padding: 8px;" onclick="resetProfileForm()">Ακύρωση</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Customer Modal -->
<div id="editCustomerModal" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
            <h3>✏️ Επεξεργασία Στοιχείων Πελάτη</h3>
            <span class="close-btn" onclick="closeCustomerModal()">×</span>
        </div>
        <div class="modal-body">
            <form method="post" asp-page-handler="UpdateCustomer" class="modal-form">
                <input type="hidden" name="id" id="editCustomerId" />
                <div class="form-group">
                    <label>Όνομα Πελάτη</label>
                    <input type="text" name="name" id="editCustomerName" class="form-control" placeholder="π.χ. ΦΛΕΣΣΑΣ Α.Ε." required />
                </div>
                <div class="form-group">
                    <label>Σημειώσεις / Περιγραφή</label>
                    <textarea name="notes" id="editCustomerNotes" class="form-control" rows="3" placeholder="π.χ. Κεντρικά γραφεία και υποκαταστήματα"></textarea>
                </div>
                <button type="submit" class="btn btn-login">💾 Αποθήκευση</button>
            </form>
        </div>
    </div>
</div>

<style>
    /* Stats Panel */
    .stats-panel {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 15px;
        margin-bottom: 25px;
    }

    .stat-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px -4px rgba(0, 0, 0, 0.2);
    }

    .stat-icon {
        font-size: 28px;
        background-color: #12121A;
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border-color);
    }

    .stat-info {
        display: flex;
        flex-direction: column;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 700;
        color: white;
        line-height: 1.2;
    }

