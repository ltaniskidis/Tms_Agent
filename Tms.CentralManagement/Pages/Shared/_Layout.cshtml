@inject Tms.CentralManagement.Data.CentralDbContext DbContext
@{
    var layoutCurrentSystemVer = DbContext.Versions.Where(v => v.TargetType == "System" && v.IsCurrent).Select(v => v.VersionNumber).FirstOrDefault() ?? "1.5.0";
}
<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Central Version Management</title>
    <style>
        :root {
            --bg-color: #0B0B0F;
            --sidebar-bg: #111116;
            --card-bg: #171721;
            --border-color: #262636;
            --text-primary: #FFFFFF;
            --text-secondary: #9CA3AF;
            --accent: #6366F1;
            --accent-hover: #4F46E5;
            --success: #10B981;
            --danger: #EF4444;
            --warning: #F59E0B;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Sidebar */
        aside {
            width: 250px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            padding: 20px;
            flex-shrink: 0;
        }

        .logo-area {
            margin-bottom: 30px;
            padding: 10px;
        }

        .logo-title {
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 1.5px;
            color: var(--text-primary);
        }

        .logo-sub {
            font-size: 11px;
            color: var(--accent);
            font-weight: 600;
        }

        nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex-grow: 1;
        }

        nav a {
            color: var(--text-secondary);
            text-decoration: none;
            padding: 12px 15px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        nav a:hover {
            background-color: #1A1A26;
            color: var(--text-primary);
        }

        nav a.active {
            background-color: #202030;
            color: var(--accent);
            font-weight: 600;
        }

        .footer-info {
            font-size: 11px;
            color: var(--text-secondary);
            padding: 10px;
            border-top: 1px solid var(--border-color);
            margin-top: 20px;
        }

        /* Main Content */
        main {
            flex-grow: 1;
            padding: 30px 40px;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        header {
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 {
            font-size: 24px;
            font-weight: 600;
        }

        /* Common Components */
        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 15px;
            color: var(--accent);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Buttons */
        .btn {
            background-color: var(--accent);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .btn:hover {
            background-color: var(--accent-hover);
        }

        .btn-outline {
            background-color: transparent;
            border: 1.5px solid var(--border-color);
            color: var(--text-secondary);
        }

        .btn-outline:hover {
            background-color: #1C1C2A;
            color: var(--text-primary);
        }

        .btn-danger {
            background-color: var(--danger);
        }

        .btn-danger:hover {
            background-color: #DC2626;
        }

        /* Badges */
        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
            color: white;
            display: inline-block;
        }

        .badge-success { background-color: var(--success); }
        .badge-danger { background-color: var(--danger); }
        .badge-warning { background-color: var(--warning); }
        .badge-info { background-color: var(--accent); }
        .badge-secondary { background-color: #4B5563; }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th {
            text-align: left;
            padding: 12px 15px;
            color: var(--text-secondary);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--border-color);
        }

        td {
            padding: 15px;
            border-bottom: 1px solid var(--border-color);
            font-size: 14px;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background-color: #1C1C28;
        }

        /* Form styling */
        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            background-color: #12121A;
            border: 1.5px solid var(--border-color);
            border-radius: 6px;
            padding: 10px 12px;
            color: white;
            font-size: 14px;
            transition: border 0.2s;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--accent);
            background-color: #161622;
        }

        textarea.form-control {
            resize: vertical;
            min-height: 80px;
        }

        /* Responsive Split Container */
        .responsive-split {
            display: flex;
            gap: 20px;
            align-items: flex-start;
        }

        @@media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            aside {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid var(--border-color);
                padding: 15px;
            }

            .logo-area {
                margin-bottom: 15px;
                text-align: center;
            }

            nav {
                flex-direction: row;
                flex-wrap: wrap;
                justify-content: center;
                gap: 5px;
            }

            nav a {
                padding: 8px 12px;
                font-size: 13px;
            }

            .footer-info {
                display: none; /* Hide verbose footer on mobile to save vertical space */
            }

            main {
                padding: 20px 15px;
            }

            .responsive-split {
                flex-direction: column;
                align-items: stretch !important;
            }
            
            .responsive-split > div {
                flex: 1 !important;
                width: 100% !important;
                min-width: unset !important;
            }

            header {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            table {
                display: block;
                overflow-x: auto;
                width: 100%;
            }

            /* Responsive tabs */
            .tabs {
                flex-wrap: wrap;
                gap: 5px !important;
            }

            .tab-btn {
                padding: 8px 10px !important;
                font-size: 12px !important;
            }
        }
    </style>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar -->
        <aside>
            <div class="logo-area">
                <div class="logo-title" style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <span>TMS CENTRAL</span>
                    <span class="badge" style="font-size: 10px; background: rgba(99, 102, 241, 0.15); color: #818CF8; border: 1px solid rgba(99, 102, 241, 0.3); padding: 2px 6px; border-radius: 6px;">v@(layoutCurrentSystemVer)</span>
                </div>
                <div class="logo-sub">Κεντρική Διαχείριση</div>
            </div>
            <nav>
                <a href="/" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" || ViewContext.RouteData.Values["page"]?.ToString() == "" ? "active" : "")">
                    <span>📊</span> Dashboard Πελατών
                </a>
                <a href="/Clients" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/Clients" ? "active" : "")">
                    <span>👥</span> Διαχείριση Πελατών
                </a>
                <a href="/Versions" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/Versions" ? "active" : "")">
                    <span>📦</span> Ιστορικό Εκδόσεων
                </a>
                <a href="/Logs" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/Logs" ? "active" : "")">
                    <span>📋</span> Ιστορικό Ενημερώσεων
                </a>
                <a href="/ConsoleUsers" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/ConsoleUsers" ? "active" : "")">
                    <span>🔑</span> Χρήστες Κονσόλας
                </a>
                @if (User.IsInRole("SuperAdmin"))
                {
                    <a href="/Broadcasts" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/Broadcasts" ? "active" : "")">
                        <span>📢</span> Ενημερώσεις &amp; Νέα
                    </a>
                    <a href="/SupportTickets" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/SupportTickets" ? "active" : "")">
                        <span>✉️</span> Αιτήματα Support
                    </a>
                    <a href="/SmtpSettings" class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/SmtpSettings" ? "active" : "")">
                        <span>⚙️</span> Ρυθμίσεις SMTP
                    </a>
                }
            </nav>
            <div class="footer-info">
                Χρήστης: <strong>@User.Identity.Name</strong>
                <br />
                <a href="/Login?handler=Logout" style="color: var(--danger); text-decoration: none; display: inline-block; margin-top: 5px;">🚪 Αποσύνδεση</a>
                <br /><br />
                Central Server v@(layoutCurrentSystemVer)
                <br />
                SQLite Active
            </div>
        </aside>
    }

    <!-- Main Content Area -->
    <main>
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
