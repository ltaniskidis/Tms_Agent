<script>
    // Customer Modal Operations
    function openEditCustomerModal(btn) {
        var id = btn.getAttribute("data-id");
        var name = btn.getAttribute("data-name");
        var notes = btn.getAttribute("data-notes");

        document.getElementById("editCustomerId").value = id;
        document.getElementById("editCustomerName").value = name;
        document.getElementById("editCustomerNotes").value = notes;

        document.getElementById("editCustomerModal").style.display = "flex";
    }

    function closeCustomerModal() {
        document.getElementById("editCustomerModal").style.display = "none";
    }

    // Tab switching for page tabs
    function switchPageTab(tabId) {
        document.querySelectorAll('.page-tab-content').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
        
        var targetContent = document.getElementById(tabId);
        if (targetContent) {
            targetContent.style.display = 'block';
        }
        
        // Find tab button that matches tabId
        var btn = document.querySelector(`button[onclick*="${tabId}"]`);
        if (btn) {
            btn.classList.add('active');
        }
        
        sessionStorage.setItem('activeClientsPageTab', tabId);
    }

    // Real-time customer cards filtering
    function filterCustomers() {
        var query = document.getElementById('customer-search-input').value.toLowerCase().trim();
        
        if (query === '') {
            document.querySelectorAll('.customer-card').forEach(card => {
                card.style.display = 'block';
            });
            document.querySelectorAll('.customer-machines-table tbody tr').forEach(tr => {
                tr.style.display = 'table-row';
            });
            return;
        }

        document.querySelectorAll('.customer-card').forEach(card => {
            var customerHeader = card.querySelector('.customer-header');
            var customerName = customerHeader.querySelector('.customer-title').innerText.toLowerCase();
            var customerNotes = card.querySelector('.customer-notes')?.innerText.toLowerCase() || '';
            
            var customerMatches = customerName.includes(query) || customerNotes.includes(query);
            var customerHasMatchingMachines = false;

            var machineRows = card.querySelectorAll('.customer-machines-table tbody tr');
            machineRows.forEach(tr => {
                var rowText = tr.innerText.toLowerCase();
                var rowMatches = rowText.includes(query);
                if (rowMatches) {
                    tr.style.display = 'table-row';
                    customerHasMatchingMachines = true;
                } else {
                    tr.style.display = 'none';
                }
            });

            if (customerMatches || customerHasMatchingMachines) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    // Toggle showing add machine form under Customer card
    function toggleAddMachineForm(customerId) {
        var formDiv = document.getElementById('addMachineForm_' + customerId);
        if (formDiv) {
            if (formDiv.style.display === 'none') {
                formDiv.style.display = 'block';
            } else {
                formDiv.style.display = 'none';
            }
        }
    }

    // Restore page tab on load
    document.addEventListener('DOMContentLoaded', function() {
        var activeTab = sessionStorage.getItem('activeClientsPageTab') || 'pageTabCustomers';
        switchPageTab(activeTab);
    });

    // Copy Text to Clipboard Helper
    function copyText(text, btnElement) {
        navigator.clipboard.writeText(text).then(function() {
            var originalText = btnElement.innerText;
            btnElement.innerText = "✓";
            btnElement.classList.add("copied");
            btnElement.style.color = "var(--success)";
            
            setTimeout(function() {
                btnElement.innerText = originalText;
                btnElement.classList.remove("copied");
                btnElement.style.color = "";
            }, 1500);
        }).catch(function(err) {
            console.error("Could not copy text: ", err);
        });
    }

    // Apply Client Table Filters
    function applyFilters() {
        var searchQuery = document.getElementById("searchFilter").value.toLowerCase();
        var roleQuery = document.getElementById("roleFilter").value;
        var upgradeQuery = document.getElementById("upgradeFilter").value;

        var rows = document.querySelectorAll(".client-row");
        rows.forEach(function(row) {
            var name = row.getAttribute("data-name") || "";
            var guid = row.getAttribute("data-guid") || "";
            var key = row.getAttribute("data-key") || "";
            var role = row.getAttribute("data-role") || "";
            var upgrade = row.getAttribute("data-upgrade") || "";
            var profiles = row.getAttribute("data-profiles") || "";
            var afms = row.getAttribute("data-afms") || "";
            var serials = row.getAttribute("data-serials") || "";

            var matchesSearch = name.includes(searchQuery) || 
                                guid.includes(searchQuery) || 
                                key.includes(searchQuery) || 
                                profiles.includes(searchQuery) || 
                                afms.includes(searchQuery) || 
                                serials.includes(searchQuery);
            var matchesRole = roleQuery === "All" || role === roleQuery;
            var matchesUpgrade = upgradeQuery === "All" || upgrade === upgradeQuery;

            if (matchesSearch && matchesRole && matchesUpgrade) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

     // Modal Operations from Button Data Attributes
    function openModalFromBtn(btn) {
        var id = btn.getAttribute("data-id");
        var name = btn.getAttribute("data-name");
        var role = btn.getAttribute("data-role");
        var guid = btn.getAttribute("data-guid");
        var apiKey = btn.getAttribute("data-apikey");
        var isUpgradeEnabled = btn.getAttribute("data-upgrade") === "true";
        var canViewLogs = btn.getAttribute("data-viewlogs") === "true";
        var canRunUpdates = btn.getAttribute("data-runupdates") === "true";
        var startWithWindows = btn.getAttribute("data-startwithwindows") === "true";
        var usersJsonString = btn.getAttribute("data-users");
        var profilesJsonString = btn.getAttribute("data-profiles");
        var alias = btn.getAttribute("data-alias") || "";
        var customerId = btn.getAttribute("data-customerid") || "";
        
        openModal(id, name, role, guid, apiKey, isUpgradeEnabled, canViewLogs, canRunUpdates, startWithWindows, usersJsonString, profilesJsonString, alias, customerId);
    }

    // Modal Operations
    function openModal(id, name, role, guid, apiKey, isUpgradeEnabled, canViewLogs, canRunUpdates, startWithWindows, usersJsonString, profilesJsonString, alias, customerId) {
        document.getElementById("modalTitle").innerText = "⚙️ Διαχείριση Μηχανήματος: " + name;
        document.getElementById("modalGuid").innerText = guid;
        document.getElementById("modalApiKey").innerText = apiKey;

        // Populate Forms IDs
        document.getElementById("modalSettingsId").value = id;
        document.getElementById("modalRegenId").value = id;
        document.getElementById("modalAddUserClientId").value = id;

        // Populate Settings values
        document.getElementById("modalMachineName").value = name;
        document.getElementById("modalAlias").value = alias;
        document.getElementById("modalCustomerId").value = customerId;
        document.getElementById("modalMachineRole").value = role;
        document.getElementById("modalIsUpgradeEnabled").checked = isUpgradeEnabled;
        document.getElementById("modalCanOperatorViewLogs").checked = canViewLogs;
        document.getElementById("modalCanOperatorRunUpdates").checked = canRunUpdates;
        document.getElementById("modalStartWithWindows").checked = startWithWindows;

        // Parse and Render Users
        var users = JSON.parse(usersJsonString || "[]");
        renderUsersList(users);

        // Parse and Render Profiles
        var profiles = JSON.parse(profilesJsonString || "[]");
        renderProfilesList(profiles, id);

        // Save state to sessionStorage
        sessionStorage.setItem("activeModalClientId", id);

        // Restore tab or default to settings
        var savedTab = sessionStorage.getItem("activeModalTab") || 'settings';
        switchModalTab(savedTab);

        // Show Modal
        document.getElementById("manageModal").style.display = "flex";
    }

    function closeModal() {
        document.getElementById("manageModal").style.display = "none";
        // Clear state from sessionStorage
        sessionStorage.removeItem("activeModalClientId");
        sessionStorage.removeItem("activeModalTab");
    }

    // Close modal if user clicks outside content
    window.onclick = function(event) {
        var modal = document.getElementById("manageModal");
        if (event.target === modal) {
            closeModal();
        }
    }

    function switchModalTab(tabName) {
        var btnSettings = document.getElementById("tabSettingsBtn");
        var btnUsers = document.getElementById("tabUsersBtn");
        var btnProfiles = document.getElementById("tabProfilesBtn");
        
        var contentSettings = document.getElementById("tabContentSettings");
        var contentUsers = document.getElementById("tabContentUsers");
        var contentProfiles = document.getElementById("tabContentProfiles");

        btnSettings.classList.remove("active");
        btnUsers.classList.remove("active");
        btnProfiles.classList.remove("active");

        contentSettings.style.display = "none";
        contentUsers.style.display = "none";
        contentProfiles.style.display = "none";

        if (tabName === 'settings') {
            btnSettings.classList.add("active");
            contentSettings.style.display = "block";
        } else if (tabName === 'users') {
            btnUsers.classList.add("active");
            contentUsers.style.display = "block";
        } else if (tabName === 'profiles') {
            btnProfiles.classList.add("active");
            contentProfiles.style.display = "block";
        }

        sessionStorage.setItem("activeModalTab", tabName);
    }

    // Auto-restore modal state on reload
    window.addEventListener("DOMContentLoaded", function() {
        var activeClientId = sessionStorage.getItem("activeModalClientId");
        if (activeClientId) {
            var btn = document.querySelector('button.btn-manage[data-id="' + activeClientId + '"]');
            if (btn) {
                openModalFromBtn(btn);
            } else {
                sessionStorage.removeItem("activeModalClientId");
                sessionStorage.removeItem("activeModalTab");
            }
        }
    });

    // Helper functions for profiles list
    var currentMachineProfiles = [];

    function renderProfilesList(profiles, machineId) {
        currentMachineProfiles = profiles;
        var listContainer = document.getElementById("modalProfilesList");
        var noProfilesMsg = document.getElementById("modalNoProfilesMsg");
        
        // Initialize form for this machineId first (crucial for clients with 0 profiles)
        resetProfileForm(machineId);
        
        var activeProfiles = profiles.filter(function(p) { return !p.IsPendingDelete; });
        document.getElementById("modalProfilesCount").innerText = activeProfiles.length;
        document.getElementById("modalProfilesCountText").innerText = activeProfiles.length;

        // Clear previous list
        listContainer.innerHTML = "";

        if (activeProfiles.length === 0) {
            noProfilesMsg.style.display = "block";
            listContainer.style.display = "none";
            return;
        }

        noProfilesMsg.style.display = "none";
        listContainer.style.display = "grid";

        activeProfiles.forEach(function(profile) {
            var card = document.createElement("div");
            card.className = "profile-item-card";

            var info = document.createElement("div");
            info.className = "profile-item-info";

            var title = document.createElement("div");
            title.className = "profile-item-title";
            title.innerText = profile.ProfileName + " (" + profile.ProfileId + ")";
            if (profile.IsPendingDelete) {
                title.innerHTML += " <span class='badge badge-danger' style='font-size:8px; padding:1px 3px; margin-left:5px;'>Προς Διαγραφή</span>";
            }
            info.appendChild(title);

            var sub = document.createElement("div");
            sub.className = "profile-item-sub";
            sub.innerHTML = "<span>ΑΦΜ: " + (profile.Afm || "-") + "</span>" +
                            "<span>SN: " + (profile.SerialNumber || "-") + "</span>" +
                            "<span>Χρήστες: " + profile.ActiveUsersCount + "</span>" +
                            "<span>Έκδοση: v" + profile.LastUpdatedVersion + "</span>" +
                            "<span style='grid-column: 1 / -1; color: var(--accent);'>Emails: " + (profile.Emails || "-") + "</span>";
            info.appendChild(sub);
            card.appendChild(info);

            // Actions
            var actions = document.createElement("div");
            actions.className = "profile-item-actions";

            // Edit button
            var btnEdit = document.createElement("button");
            btnEdit.type = "button";
            btnEdit.className = "btn btn-mini btn-manage";
            btnEdit.title = "Επεξεργασία";
            btnEdit.innerText = "✏️";
            btnEdit.onclick = function() {
                loadProfileIntoForm(profile);
            };
            actions.appendChild(btnEdit);

            // Delete Form
            if (!profile.IsPendingDelete) {
                var deleteForm = document.createElement("form");
                deleteForm.method = "post";
                deleteForm.action = "/Clients?handler=DeleteClientProfile";
                deleteForm.style.display = "inline";
                deleteForm.onsubmit = function() {
                    return confirm("Είστε σίγουροι ότι θέλετε να ζητήσετε τη διαγραφή αυτής της εταιρείας;");
                };

                // Add anti-forgery token
                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (token) {
                    deleteForm.appendChild(token.cloneNode(true));
                }

                var inputProfileId = document.createElement("input");
                inputProfileId.type = "hidden";
                inputProfileId.name = "profileId";
                inputProfileId.value = profile.Id;
                deleteForm.appendChild(inputProfileId);

                var btnDelete = document.createElement("button");
                btnDelete.type = "submit";
                btnDelete.className = "btn btn-mini btn-danger-action";
                btnDelete.title = "Διαγραφή";
                btnDelete.innerText = "🗑️";
                deleteForm.appendChild(btnDelete);

                actions.appendChild(deleteForm);
            }

            card.appendChild(actions);
            listContainer.appendChild(card);
        });
    }

    function loadProfileIntoForm(profile) {
        document.getElementById("profileFormTitle").innerText = "✏️ Επεξεργασία Εταιρείας: " + profile.ProfileName;
        document.getElementById("profileFormTitle").style.color = "#F59E0B";
        document.getElementById("profileForm").action = "/Clients?handler=SaveClientProfileSettings";
        document.getElementById("profileFormEditId").value = profile.Id;

        // Hide ProfileId field group because ProfileId cannot be edited (it's key on Agent)
        document.getElementById("profileIdFieldGroup").style.display = "none";
        document.getElementById("profileFormProfileId").required = false;

        // Populate values
        document.getElementById("profileFormProfileName").value = profile.ProfileName;
        document.getElementById("profileFormAfm").value = profile.Afm;
        document.getElementById("profileFormSerial").value = profile.SerialNumber;
        document.getElementById("profileFormUsers").value = profile.ActiveUsersCount;
        document.getElementById("profileFormExe").value = profile.TargetExeName;
        document.getElementById("profileFormFolder").value = profile.TargetFolder;
        document.getElementById("profileFormEmails").value = profile.Emails || "";
        document.getElementById("profileFormConnectionString").value = profile.ConnectionString;

        var connType = profile.ConnectionStringType || "Direct";
        document.getElementById("profileFormConnectionStringType").value = connType;
        document.getElementById("profileFormDbServer").value = profile.DbServer || "";
        document.getElementById("profileFormDbName").value = profile.DbName || "";
        document.getElementById("profileFormDbWindowsAuth").checked = profile.DbUseWindowsAuth === true;
        document.getElementById("profileFormDbUser").value = profile.DbUser || "";
        document.getElementById("profileFormDbPassword").value = profile.DbPassword || "";
        document.getElementById("profileFormConfigPath").value = profile.ConfigFilePath || "";

        toggleConnectionStringFields();
        toggleWindowsAuthFields();
        document.getElementById("folderSuggestions").style.display = "none";

        // Action Buttons
        document.getElementById("profileFormSubmitBtn").innerText = "💾 Αποθήκευση Αλλαγών";
        document.getElementById("profileFormSubmitBtn").className = "btn btn-login btn-sm";
        document.getElementById("profileFormCancelBtn").style.display = "inline-block";
        
        // Scroll to form
        document.getElementById("profileFormSection").scrollIntoView({ behavior: 'smooth' });
    }

    function resetProfileForm(machineId) {
        var mId = machineId || document.getElementById("profileFormClientId").value;
        
        document.getElementById("profileFormTitle").innerText = "➕ Προσθήκη Νέας Εταιρείας";
        document.getElementById("profileFormTitle").style.color = "var(--accent)";
        document.getElementById("profileForm").action = "/Clients?handler=AddClientProfile";
        document.getElementById("profileFormClientId").value = mId;
        document.getElementById("profileFormEditId").value = "";

        // Show ProfileId field group and make it required
        document.getElementById("profileIdFieldGroup").style.display = "block";
        document.getElementById("profileFormProfileId").required = true;

        // Find default profile from current machine to copy settings by default
        var defaultProfile = null;
        if (currentMachineProfiles && currentMachineProfiles.length > 0 && currentMachineProfiles[0].ClientMachineId == mId) {
            defaultProfile = currentMachineProfiles[0];
        }

        // Reset inputs
        document.getElementById("profileFormProfileId").value = "";
        document.getElementById("profileFormProfileName").value = "";
        document.getElementById("profileFormAfm").value = "";
        document.getElementById("profileFormSerial").value = "";
        document.getElementById("profileFormUsers").value = "1";
        document.getElementById("profileFormExe").value = "TIMOLOGISI.exe";
        document.getElementById("profileFormFolder").value = "";
        document.getElementById("profileFormEmails").value = "support@cleverdata.gr,l.taniskdis@cleverdata.gr,e.kordouli@cleverdata.gr";
        document.getElementById("profileFormConnectionString").value = defaultProfile ? (defaultProfile.ConnectionString || "") : "";

        document.getElementById("profileFormConnectionStringType").value = defaultProfile ? (defaultProfile.ConnectionStringType || "Direct") : "Direct";
        document.getElementById("profileFormDbServer").value = defaultProfile ? (defaultProfile.DbServer || "") : "";
        document.getElementById("profileFormDbName").value = defaultProfile ? (defaultProfile.DbName || "") : "";
        document.getElementById("profileFormDbWindowsAuth").checked = defaultProfile ? (defaultProfile.DbUseWindowsAuth === true) : false;
        document.getElementById("profileFormDbUser").value = defaultProfile ? (defaultProfile.DbUser || "") : "";
        document.getElementById("profileFormDbPassword").value = defaultProfile ? (defaultProfile.DbPassword || "") : "";
        document.getElementById("profileFormConfigPath").value = defaultProfile ? (defaultProfile.ConfigFilePath || "") : "";

        toggleConnectionStringFields();
        toggleWindowsAuthFields();
        document.getElementById("folderSuggestions").style.display = "none";

        // Action Buttons
        document.getElementById("profileFormSubmitBtn").innerText = "➕ Προσθήκη Εταιρείας";
        document.getElementById("profileFormSubmitBtn").className = "btn btn-login btn-sm";
        document.getElementById("profileFormCancelBtn").style.display = "none";
    }

    function toggleDbPasswordVisibility() {
        var pwdInput = document.getElementById("profileFormDbPassword");
        var toggleBtn = document.getElementById("toggleDbPasswordBtn");
        if (pwdInput.type === "password") {
            pwdInput.type = "text";
            toggleBtn.innerText = "👁️‍🗨️";
        } else {
            pwdInput.type = "password";
            toggleBtn.innerText = "👁️";
        }
    }

    function triggerFolderBrowse(inputId) {
        var dummy = document.getElementById("folderBrowserDummy");
        dummy.dataset.targetInput = inputId;
        dummy.click();
    }

    function handleFolderSelected(input, defaultInputId) {
        var inputId = input.dataset.targetInput || defaultInputId;
        if (input.files.length > 0) {
            var sampleFile = input.files[0];
            var relativePath = sampleFile.webkitRelativePath || "";
            var folderName = relativePath.split('/')[0] || "";
            
            var targetInput = document.getElementById(inputId);
            if (targetInput) {
                if (folderName) {
                    // Default to Program Files (x86) since it is extremely common for desktop apps
                    var defaultPath = "C:\\Program Files (x86)\\" + folderName;
                    targetInput.value = defaultPath;

                    // Populate suggestions
                    var suggestionsList = document.getElementById("folderSuggestionsList");
                    suggestionsList.innerHTML = "";
                    
                    var options = [
                        "C:\\Program Files (x86)\\" + folderName,
                        "C:\\Program Files\\" + folderName,
                        "C:\\" + folderName
                    ];
                    
                    options.forEach(function(opt) {
                        var btn = document.createElement("button");
                        btn.type = "button";
                        btn.className = "btn btn-mini";
                        btn.style.textAlign = "left";
                        btn.style.width = "100%";
                        btn.style.padding = "6px 10px";
                        btn.style.backgroundColor = "#1A1A26";
                        btn.style.border = "1px solid var(--border-color)";
                        btn.style.color = "#E2E8F0";
                        btn.style.cursor = "pointer";
                        btn.style.fontSize = "11px";
                        btn.style.borderRadius = "4px";
                        btn.innerText = opt;
                        btn.onclick = function() {
                            targetInput.value = opt;
                            // update file paths if config path exists
                            var configInput = document.getElementById("profileFormConfigPath");
                            if (configInput && configInput.value) {
                                var parts = configInput.value.split('\\');
                                var filename = parts[parts.length - 1];
                                configInput.value = opt + "\\" + filename;
                            }
                        };
                        suggestionsList.appendChild(btn);
                    });
                    
                    document.getElementById("folderSuggestions").style.display = "block";
                }
            }
        }
    }

    function triggerFileBrowse(inputId) {
        var dummy = document.getElementById("fileBrowserDummy");
        dummy.dataset.targetInput = inputId;
        dummy.click();
    }

    function handleFileSelected(input, defaultInputId) {
        var inputId = input.dataset.targetInput || defaultInputId;
        if (input.files.length > 0) {
            var file = input.files[0];
            var filename = file.name;
            var targetInput = document.getElementById(inputId);
            if (targetInput) {
                var folderInput = document.getElementById("profileFormFolder");
                var baseDir = folderInput ? folderInput.value : "C:\\";
                if (baseDir && !baseDir.endsWith("\\")) {
                    baseDir += "\\";
                }
                targetInput.value = baseDir + filename;
            }
        }
    }

    function toggleConnectionStringFields() {
        var type = document.getElementById("profileFormConnectionStringType").value;
        var sDirect = document.getElementById("sectionConnDirect");
        var sBuilder = document.getElementById("sectionConnBuilder");
        var sConfigFile = document.getElementById("sectionConnConfigFile");

        if (type === "Direct") {
            sDirect.style.display = "block";
            sBuilder.style.display = "none";
            sConfigFile.style.display = "none";
        } else if (type === "Builder") {
            sDirect.style.display = "none";
            sBuilder.style.display = "block";
            sConfigFile.style.display = "none";
            compileConnectionStringFromBuilder();
        } else if (type === "ConfigFile") {
            sDirect.style.display = "none";
            sBuilder.style.display = "none";
            sConfigFile.style.display = "block";
        }
    }

    function toggleWindowsAuthFields() {
        var useWindows = document.getElementById("profileFormDbWindowsAuth").checked;
        var credentialsRow = document.getElementById("builderCredentialsRow");
        if (useWindows) {
            credentialsRow.style.display = "none";
        } else {
            credentialsRow.style.display = "grid";
        }
    }

    function compileConnectionStringFromBuilder() {
        var server = document.getElementById("profileFormDbServer").value.trim();
        var db = document.getElementById("profileFormDbName").value.trim();
        var useWindows = document.getElementById("profileFormDbWindowsAuth").checked;
        var user = document.getElementById("profileFormDbUser").value.trim();
        var pass = document.getElementById("profileFormDbPassword").value.trim();

        if (!server) {
            document.getElementById("profileFormConnectionString").value = "";
            return;
        }

        var parts = ["Server=" + server];
        if (db) {
            parts.push("Database=" + db);
        }

        if (useWindows) {
            parts.push("Integrated Security=True");
        } else {
            if (user) parts.push("User Id=" + user);
            if (pass) parts.push("Password=" + pass);
        }

        parts.push("TrustServerCertificate=True");
        var connStr = parts.join(";") + ";";
        document.getElementById("profileFormConnectionString").value = connStr;
    }

    function renderUsersList(users) {
        var listUl = document.getElementById("modalUsersList");
        var noUsersMsg = document.getElementById("modalNoUsersMsg");
        document.getElementById("modalUsersCount").innerText = users.length;

        // Clear previous
        listUl.innerHTML = "";

        if (users.length === 0) {
            noUsersMsg.style.display = "block";
            listUl.style.display = "none";
            return;
        }

        noUsersMsg.style.display = "none";
        listUl.style.display = "block";

        users.forEach(function(user) {
            var li = document.createElement("li");
            li.className = "user-item";

            var infoDiv = document.createElement("div");
            infoDiv.className = "user-info";

            var nameSpan = document.createElement("span");
            nameSpan.className = "user-name";
            nameSpan.innerText = user.Username;
            infoDiv.appendChild(nameSpan);

            var roleSpan = document.createElement("span");
            roleSpan.className = "user-role " + (user.Role === "Admin" ? "role-admin" : "role-operator");
            roleSpan.innerText = user.Role;
            infoDiv.appendChild(roleSpan);

            var passSpan = document.createElement("span");
            passSpan.className = "user-pass";
            passSpan.title = "Κωδικός";
            passSpan.innerText = "🔑 " + user.Password;
            infoDiv.appendChild(passSpan);

            li.appendChild(infoDiv);

            // Create Delete Form
            var form = document.createElement("form");
            form.method = "post";
            form.action = "/Clients?handler=DeleteAgentUser";
            form.style.display = "inline";

            // Add anti-forgery token
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                form.appendChild(token.cloneNode(true));
            }

            var inputId = document.createElement("input");
            inputId.type = "hidden";
            inputId.name = "userId";
            inputId.value = user.Id;
            form.appendChild(inputId);

            var btnDelete = document.createElement("button");
            btnDelete.type = "submit";
            btnDelete.className = "btn-delete-user";
            btnDelete.title = "Διαγραφή Χρήστη";
            btnDelete.innerText = "❌";
            form.appendChild(btnDelete);

            li.appendChild(form);
            listUl.appendChild(li);
        });
    }
</script>
