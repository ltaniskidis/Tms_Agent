<Window x:Class="Tms.Agent.Wpf.UpgradeProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TMS Agent - Αναβάθμιση σε εξέλιξη" 
        Height="150" Width="400"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="False" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif">

    <Border CornerRadius="8" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <TextBlock Text="Εγκατάσταση Αναβάθμισης..." FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="—" 
                        Foreground="#A0A0B0" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        FontSize="14"
                        FontWeight="Bold"
                        Width="24" Height="24" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" 
                        Cursor="Hand"
                        Click="MinimizeButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2B2B3C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

            <!-- Progress Bar -->
            <ProgressBar Grid.Row="1" Height="15" Value="{Binding WizardProgress}" Minimum="0" Maximum="100" Margin="0,15,0,10" VerticalAlignment="Center">
                <ProgressBar.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="#A855F7" Offset="1"/>
                    </LinearGradientBrush>
                </ProgressBar.Foreground>
            </ProgressBar>

            <!-- Status Text -->
            <TextBlock Grid.Row="2" Text="{Binding WizardStatus}" FontSize="12" Foreground="#A0A0B0" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </Grid>
    </Border>
</Window>
