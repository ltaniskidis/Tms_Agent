<Window x:Class="Tms.Agent.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tms.Agent.Wpf"
        xmlns:vm="clr-namespace:Tms.Agent.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="650" Width="1050"
        Icon="logo.png"
        Background="#0F0F12"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif">

    <Window.Resources>
        <!-- Converters / Helpers -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Style for Sidebar Buttons -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#A0A0B0" />
            <Setter Property="Height" Value="45" />
            <Setter Property="Margin" Value="0,5,0,5" />
            <Setter Property="Padding" Value="15,0,15,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E1E2C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Sidebar Button Active State -->
        <Style x:Key="SidebarButtonActive" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Input Field Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#16161F" />
            <Setter Property="BorderBrush" Value="#2B2B3C" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="10,8,10,8" />
            <Setter Property="SelectionBrush" Value="#6366F1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Background" Value="#1C1C2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#16161F" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="8,5,8,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#4F46E5"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#16161F"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2B2B3C"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,5,8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ToggleButton Grid.ColumnSpan="2" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press" Focusable="false">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid HorizontalAlignment="Right" Width="24" Margin="0,0,5,0">
                                                <TextBlock Text="▼" Foreground="#A0A0B0" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <ContentPresenter Grid.Column="0" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            
                            <Popup x:Name="PART_Popup" Grid.ColumnSpan="2" Placement="Bottom" 
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="6" 
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" 
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer x:Name="PART_ScrollViewer" SnapsToDevicePixels="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard Button Style -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#6366F1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10,16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3B3B4F" />
                                <Setter Property="Foreground" Value="#888899" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outline Button Style -->
        <Style TargetType="Button" x:Key="OutlineButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A0A0B0" />
            <Setter Property="BorderBrush" Value="#2B2B3C" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E1E2C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="240" />
            <!-- Main Content Area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="0,0,1,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Logo/Title -->
                    <RowDefinition Height="Auto" /> <!-- Spacer -->
                    <RowDefinition Height="*" />    <!-- Navigation Items -->
                    <RowDefinition Height="Auto" /> <!-- Footer version/settings -->
                </Grid.RowDefinitions>

                <!-- Title Section -->
                <StackPanel Grid.Row="0" Margin="5,10,5,20">
                    <TextBlock Text="TMS AGENT" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Text="{Binding AppVersion, StringFormat='Έκδοση {0}'}" FontSize="11" Foreground="#6366F1" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Navigation List -->
                <StackPanel Grid.Row="2">
                    <!-- Dashboard Link -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Dashboard">
                                        <Setter Property="Background" Value="#252538"/>
                                        <Setter Property="Foreground" Value="#6366F1"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Setup Profiles Link -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Config">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Config">
                                        <Setter Property="Background" Value="#252538"/>
                                        <Setter Property="Foreground" Value="#6366F1"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏢" Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Προφίλ Εταιρειών" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Agent Settings Link -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="AgentSettings">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="AgentSettings">
                                        <Setter Property="Background" Value="#252538"/>
                                        <Setter Property="Foreground" Value="#6366F1"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Ρυθμίσεις Agent" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Local Users Link (Admin/Owner only) -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Users" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Users">
                                        <Setter Property="Background" Value="#252538"/>
                                        <Setter Property="Foreground" Value="#6366F1"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Διαχείριση Χρηστών" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Logs Link -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Logs" Visibility="{Binding CanViewLogs, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="Logs">
                                        <Setter Property="Background" Value="#252538"/>
                                        <Setter Property="Foreground" Value="#6366F1"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Logs Εγκατάστασης" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3" Margin="5" BorderBrush="#2B2B3C" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Ρόλος Χρήστη:" FontSize="10" Foreground="#A0A0B0" Margin="0,0,0,3"/>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="{Binding CurrentRoleText}" FontSize="12" FontWeight="Bold" Foreground="{Binding RoleColor}" VerticalAlignment="Center" Margin="0,0,0,5"/>
                            <Button Content="{Binding RoleActionButtonText}" Style="{StaticResource OutlineButton}" Padding="8,4,8,4" FontSize="10" Command="{Binding ToggleRoleCommand}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        
                        <TextBlock Text="Πληροφορίες Agent:" FontSize="10" Foreground="#A0A0B0" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="11" FontWeight="SemiBold" Foreground="#10B981" Margin="0,0,0,0" TextWrapping="Wrap"/>
                        
                        <TextBlock Text="{Binding SystemVersionWarning}" FontSize="11" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right Side Main Content Panel -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Content Header -->
                <RowDefinition Height="*" />    <!-- Content Body -->
            </Grid.RowDefinitions>

            <!-- Dashboard View -->
            <Grid Grid.Row="1" x:Name="DashboardPanel" Margin="0,15,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Dashboard">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="200" /> <!-- Release Notes detail panel -->
                </Grid.RowDefinitions>

                <!-- Actions Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Εταιρικά Προφίλ &amp; Βάσεις Δεδομένων" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="Έλεγχος Νέων Εκδόσεων" Style="{StaticResource PrimaryButton}" Command="{Binding CheckUpdatesCommand}" HorizontalAlignment="Right" Width="180"/>
                </Grid>

                <!-- Cards Grid -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                    <ItemsControl ItemsSource="{Binding Profiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="250" Margin="-5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="5" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="10" Padding="15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" /> <!-- Company / AFM -->
                                            <RowDefinition Height="Auto" /> <!-- Versions info -->
                                            <RowDefinition Height="Auto" /> <!-- Status label -->
                                            <RowDefinition Height="Auto" /> <!-- Action Button -->
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding ProfileName}" FontSize="15" FontWeight="Bold" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Afm, StringFormat='ΑΦΜ: {0}'}" FontSize="11" Foreground="#A0A0B0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding CurrentVersion, StringFormat='Τρέχουσα Έκδοση: {0}'}" FontSize="12" Foreground="#FFFFFF"/>
                                            <TextBlock Text="{Binding SerialNumber, StringFormat='S/N: {0}'}" FontSize="11" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ActiveUsersCount, StringFormat='Ενεργοί Χρήστες: {0}'}" FontSize="11" Foreground="#A0A0B0"/>
                                            <TextBlock Text="{Binding TargetFolder}" FontSize="10" Foreground="#A0A0B0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Status Indicator -->
                                        <Border Grid.Row="2" CornerRadius="4" Padding="5,3,5,3" HorizontalAlignment="Left" Margin="0,0,0,15">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#252538"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ενημερωμένο">
                                                            <Setter Property="Background" Value="#064E3B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ενημερώθηκε!">
                                                            <Setter Property="Background" Value="#064E3B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Έλεγχος...">
                                                            <Setter Property="Background" Value="#78350F"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ενημέρωση...">
                                                            <Setter Property="Background" Value="#1E3A8A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                        </Border>

                                        <!-- Update Button -->
                                        <Button Grid.Row="3" Content="Αναβάθμιση Τώρα" Style="{StaticResource PrimaryButton}" 
                                                Height="32" Padding="0" Margin="0"
                                                Command="{Binding DataContext.UpdateProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.CanRunUpdates, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                                            <Button.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#6366F1" Offset="0"/>
                                                    <GradientStop Color="#A855F7" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Button.Background>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Release Notes / Details Panel -->
                <Border Grid.Row="2" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1" CornerRadius="8" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Σημειώσεις Έκδοσης (Release Notes)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#6366F1"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedProfile.AvailableVersion.ReleaseNotes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#D1D5DB" Margin="0,4,0,4" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Text="Επιλέξτε ένα προφίλ με διαθέσιμη ενημέρωση για να δείτε τις σημειώσεις έκδοσης." 
                                   FontSize="12" Foreground="#888899" FontStyle="Italic" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProfile.HasUpdate}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>

            <!-- Configuration / Editor View -->
            <Grid Grid.Row="1" x:Name="ConfigPanel" Margin="0,15,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Config">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" /> <!-- List of profiles -->
                    <ColumnDefinition Width="*" />   <!-- Editor Form -->
                </Grid.ColumnDefinitions>

                <!-- Profiles List -->
                <Border Grid.Column="0" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1" CornerRadius="8" Margin="0,0,15,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Εταιρείες" FontSize="14" FontWeight="SemiBold" Margin="5,5,5,10" Foreground="#A0A0B0"/>

                        <ListBox Grid.Row="1" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding ProfileName}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                        <TextBlock Text="{Binding Afm, StringFormat='ΑΦΜ: {0}'}" FontSize="11" Foreground="#A0A0B0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Row="2" Content="+ Προσθήκη Εταιρείας" Style="{StaticResource OutlineButton}" Margin="0,10,0,0" Command="{Binding NewProfileCommand}" IsEnabled="{Binding IsOwner}"/>
                    </Grid>
                </Border>

                <!-- Editor Form -->
                <Border Grid.Column="1" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1" CornerRadius="8" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Στοιχεία Προφίλ Εγκατάστασης" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="#6366F1"/>

                            <!-- Company Name -->
                            <TextBlock Text="Όνομα Εταιρείας / Πελάτη:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" IsReadOnly="{Binding IsSettingsLocked}"/>

                            <!-- AFM -->
                            <TextBlock Text="ΑΦΜ Εταιρείας:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditAfm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" IsReadOnly="{Binding IsSettingsLocked}"/>

                            <!-- EXE Directory Path -->
                            <TextBlock Text="Φάκελος Εγκατάστασης Desktop Εφαρμογής (.exe):" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding EditTargetFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0" IsReadOnly="{Binding IsSettingsLocked}"/>
                                <Button Grid.Column="1" Content="Αναζήτηση..." Style="{StaticResource OutlineButton}" Padding="10,0,10,0" Height="28" Command="{Binding BrowseFolderCommand}" IsEnabled="{Binding IsOwner}"/>
                            </Grid>

                            <!-- EXE File Name -->
                            <TextBlock Text="Όνομα Εκτελέσιμου Αρχείου (.exe):" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditTargetExeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" IsReadOnly="{Binding IsSettingsLocked}"/>

                            <!-- Serial Number -->
                            <TextBlock Text="Σειριακός Αριθμός Προγράμματος:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditSerialNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" IsReadOnly="True" Background="#16161F"/>

                            <!-- Active Users Count -->
                            <TextBlock Text="Ενεργοί Χρήστες:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditActiveUsersCount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" IsReadOnly="True" Background="#16161F"/>

                            <!-- Connection String Settings -->
                            <TextBlock Text="Τύπος Σύνδεσης Βάσης Δεδομένων:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding EditConnectionStringType}" Margin="0,0,0,15" Height="28" Background="#16161F" Foreground="White" BorderBrush="#2B2B3C" IsEnabled="{Binding IsOwner}">
                                <ComboBoxItem Content="Απευθείας Connection String" Tag="Direct"/>
                                <ComboBoxItem Content="Κατασκευαστής (Builder)" Tag="Builder"/>
                                <ComboBoxItem Content="Ανάγνωση από Αρχείο Ρυθμίσεων (.config / .json)" Tag="ConfigFile"/>
                            </ComboBox>

                            <!-- Direct Connection String -->
                            <StackPanel Visibility="{Binding IsDirectConnection, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="SQL Server Connection String:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditConnectionString, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" IsReadOnly="{Binding IsSettingsLocked}"/>
                            </StackPanel>

                            <!-- Connection String Builder -->
                            <StackPanel Visibility="{Binding IsBuilderConnection, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="SQL Server / Instance:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditDbServer, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" IsReadOnly="{Binding IsSettingsLocked}"/>

                                <TextBlock Text="Όνομα Βάσης Δεδομένων:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditDbName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" IsReadOnly="{Binding IsSettingsLocked}"/>

                                <CheckBox Content="Windows Authentication (Integrated Security)" IsChecked="{Binding EditDbUseWindowsAuth}" Margin="0,0,0,10" Foreground="White" IsEnabled="{Binding IsOwner}"/>

                                <StackPanel Visibility="{Binding IsNotWindowsAuth, Converter={StaticResource BoolToVis}}">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="Όνομα Χρήστη:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding EditDbUser, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsSettingsLocked}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="Κωδικός Χρήστη:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding EditDbPassword, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsSettingsLocked}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!-- Config File Path Input -->
                            <StackPanel Visibility="{Binding IsConfigFileConnection, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Διαδρομή Αρχείου Ρυθμίσεων (τοπικά):" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding EditConfigFilePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0" IsReadOnly="{Binding IsSettingsLocked}"/>
                                    <Button Grid.Column="1" Content="Αναζήτηση..." Style="{StaticResource OutlineButton}" Padding="10,0,10,0" Height="28" Command="{Binding BrowseConfigFileCommand}" IsEnabled="{Binding IsOwner}"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Test Database Connection -->
                            <Button Content="Δοκιμή Σύνδεσης Βάσης" Style="{StaticResource OutlineButton}" 
                                    HorizontalAlignment="Left" Width="180" Margin="0,0,0,20" Command="{Binding TestConnectionCommand}" IsEnabled="{Binding IsOwner}"/>

                            <!-- Current Version Config -->
                            <TextBlock Text="Τρέχουσα Έκδοση (για επαναφορά/ρύθμιση):" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditCurrentVersion, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" Width="120" HorizontalAlignment="Left" IsReadOnly="{Binding IsSettingsLocked}"/>

                            <!-- Form Actions -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="Διαγραφή" Style="{StaticResource DangerButton}" Width="110" Margin="0,0,10,0" Command="{Binding DeleteProfileCommand}" IsEnabled="{Binding IsOwner}"/>
                                <Button Content="Αποθήκευση" Style="{StaticResource PrimaryButton}" Width="130" Command="{Binding SaveProfileCommand}" IsEnabled="{Binding IsOwner}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Logs / Output View -->
            <Grid Grid.Row="1" x:Name="LogsPanel" Margin="0,15,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Logs">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Κονσόλα Καταγραφής Ενημερώσεων (Update Logs)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <!-- Log output terminal screen -->
                <Border Grid.Row="1" Background="#0A0A0D" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="8" Padding="15">
                    <TextBox Text="{Binding LogOutput, Mode=OneWay}" 
                             FontFamily="Consolas, Courier New, monospace" 
                             FontSize="12" 
                             Foreground="#10B981" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             AcceptsReturn="True" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto" 
                             TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- Agent Settings View -->
            <Grid Grid.Row="1" x:Name="AgentSettingsPanel" Margin="0,15,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="AgentSettings">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Ρυθμίσεις Συστήματος Agent" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Text="Διαχείριση των κεντρικών παραμέτρων σύνδεσης του Agent με τον Central Server." FontSize="12" Foreground="#A0A0B0" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="0,0,20,0">
                        
                        <!-- Lock Warning Banner if not Owner -->
                        <Border Background="#1E1B4B" BorderBrush="#312E81" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20" 
                                Visibility="{Binding IsSettingsLocked, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔒" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Οι ρυθμίσεις είναι κλειδωμένες" FontSize="13" FontWeight="Bold" Foreground="#E0E7FF"/>
                                    <TextBlock Text="Μόνο ο χρήστης με ρόλο 'Owner' έχει δικαίωμα να αλλάξει τις παραμέτρους σύνδεσης. Συνδεθείτε ως owner για να τις ξεκλειδώσετε." 
                                               FontSize="11" Foreground="#A5B4FC" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card: Connection Settings -->
                        <Border Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🔌 Παράμετροι Σύνδεσης" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,15"/>

                                <!-- Server URL -->
                                <TextBlock Text="Διεύθυνση Central Server (URL):" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10,8,10,8" FontSize="13" Background="#0F0F12" BorderBrush="#2B2B3C" 
                                         Foreground="#FFFFFF" CaretBrush="#6366F1" Margin="0,0,0,15"
                                         IsReadOnly="{Binding IsSettingsLocked}"/>

                                <!-- API Key -->
                                <TextBlock Text="API Key Πιστοποίησης:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10,8,10,8" FontSize="13" Background="#0F0F12" BorderBrush="#2B2B3C" 
                                         Foreground="#FFFFFF" CaretBrush="#6366F1" Margin="0,0,0,5"
                                         IsReadOnly="{Binding IsSettingsLocked}"/>
                                <TextBlock Text="Το API Key χρησιμοποιείται για την αναγνώριση και έγκριση του Agent από το Central Management." 
                                           FontSize="11" Foreground="#6B7280" Margin="0,0,0,15"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: Machine Role -->
                        <Border Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,25">
                            <StackPanel>
                                <TextBlock Text="⚙️ Ρόλος Μηχανήματος" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,15"/>
                                <TextBlock Text="Καθορίστε αν το τρέχον μηχάνημα φιλοξενεί τον SQL Server, είναι απλός Client ή και τα δύο:" 
                                           FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                <StackPanel Margin="5,0,0,5">
                                    <RadioButton Content="SQL Server (Φιλοξενεί τη Βάση Δεδομένων)" IsChecked="{Binding IsRoleSqlServer}" 
                                                 Foreground="#FFFFFF" FontSize="12" Margin="0,0,0,10" IsEnabled="{Binding IsOwner}"/>
                                    <RadioButton Content="Απλός Client (Εκτελεί μόνο την εφαρμογή)" IsChecked="{Binding IsRoleClient}" 
                                                 Foreground="#FFFFFF" FontSize="12" Margin="0,0,0,10" IsEnabled="{Binding IsOwner}"/>
                                    <RadioButton Content="Και τα δύο (SQL Server &amp; Client)" IsChecked="{Binding IsRoleBoth}" 
                                                 Foreground="#FFFFFF" FontSize="12" Margin="0,0,0,5" IsEnabled="{Binding IsOwner}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                            <!-- Test Connection -->
                            <Button Content="Έλεγχος Σύνδεσης" Style="{StaticResource OutlineButton}" Width="150" Height="36" Margin="0,0,12,0" 
                                    Command="{Binding CheckUpdatesCommand}"/>
                            
                            <!-- Discard Changes -->
                            <Button Content="Επαναφορά" Style="{StaticResource OutlineButton}" Width="120" Height="36" Margin="0,0,12,0" 
                                    Command="{Binding DiscardSettingsCommand}" IsEnabled="{Binding IsOwner}"/>

                            <!-- Save Changes -->
                            <Button Content="Αποθήκευση" Style="{StaticResource PrimaryButton}" Width="140" Height="36" 
                                    Command="{Binding SaveSettingsCommand}" IsEnabled="{Binding IsOwner}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Users Management View -->
            <Grid Grid.Row="1" x:Name="UsersPanel" Margin="0,15,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Users">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Διαχείριση Τοπικών Χρηστών" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Text="Προσθέστε ή επεξεργαστείτε τους χρήστες με δικαίωμα σύνδεσης στον τοπικό Agent." FontSize="12" Foreground="#A0A0B0" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Content Grid: Left List, Right Editor -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Users list -->
                    <Border Grid.Column="0" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="8" Padding="15" Margin="0,0,15,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Εγγεγραμμένοι Χρήστες" FontSize="13" FontWeight="SemiBold" Foreground="#A0A0B0" Margin="0,0,0,10"/>
                            
                            <ListBox Grid.Row="1" ItemsSource="{Binding LocalUsersList}" SelectedItem="{Binding SelectedUser}" 
                                     Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#2B2B3C" BorderThickness="0,0,0,1" Padding="10,8,10,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Username}" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Role, StringFormat='Ρόλος: {0}'}" FontSize="11" Foreground="#A0A0B0"/>
                                                        <TextBlock Text="  |  " FontSize="11" Foreground="#505060"/>
                                                        <TextBlock x:Name="scopeText" Text="Εφαρμογή: Agent" FontSize="11" Foreground="#A0A0B0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock x:Name="lockIcon" Grid.Column="1" Text="🔒" FontSize="12" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Username}" Value="owner">
                                                <Setter TargetName="lockIcon" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="scopeText" Property="Text" Value="Εφαρμογή: Κονσόλα &amp; Agent"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="true">
                                                            <Setter Property="Background" Value="#1E1E2C"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="true">
                                                            <Setter Property="Background" Value="#252538"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Right: Editor Form -->
                    <Border Grid.Column="1" Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="👤 Στοιχεία Χρήστη" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- Sync status message -->
                                    <TextBlock Text="{Binding UserSyncStatus}" FontSize="12" Foreground="#6366F1" Margin="0,0,0,15" FontWeight="SemiBold" TextWrapping="Wrap"/>

                                    <!-- Username field -->
                                    <TextBlock Text="Όνομα Χρήστη (Username):" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EditUserUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" 
                                             IsEnabled="{Binding IsUserEditingEnabled}" Foreground="#FFFFFF"/>

                                    <!-- Password field -->
                                    <TextBlock Text="Κωδικός Πρόσβασης (Password):" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EditUserPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" 
                                             IsEnabled="{Binding IsUserEditingEnabled}" Foreground="#FFFFFF"/>

                                    <!-- Role Selection -->
                                    <TextBlock Text="Ρόλος Χρήστη:" FontSize="12" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValuePath="Content" SelectedValue="{Binding EditUserRole}" Margin="0,0,0,25" Height="30" IsEnabled="{Binding IsUserEditingEnabled}">
                                        <ComboBoxItem Content="Operator" />
                                        <ComboBoxItem Content="Admin" />
                                    </ComboBox>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Actions -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                <Button Content="Καθαρισμός" Style="{StaticResource OutlineButton}" Width="100" Margin="0,0,10,0" 
                                        Command="{Binding NewUserCommand}"/>
                                <Button Content="Διαγραφή" Style="{StaticResource DangerButton}" Width="100" Margin="0,0,10,0" 
                                        Command="{Binding DeleteUserCommand}" IsEnabled="{Binding IsUserEditingEnabled}"/>
                                <Button Content="Αποθήκευση" Style="{StaticResource PrimaryButton}" Width="120" 
                                        Command="{Binding SaveUserCommand}" IsEnabled="{Binding IsUserEditingEnabled}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Passcode Modal Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#A0000000" Visibility="{Binding IsPasscodeModalOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="10" 
                    Width="380" Height="240" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title -->
                        <RowDefinition Height="Auto" /> <!-- Message -->
                        <RowDefinition Height="*" />    <!-- Input -->
                        <RowDefinition Height="Auto" /> <!-- Error -->
                        <RowDefinition Height="Auto" /> <!-- Actions -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔒 Απαιτείται Κωδικός Έγκρισης" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,8"/>
                    
                    <TextBlock Grid.Row="1" Text="Η αναβάθμιση αυτής της εταιρείας απαιτεί κωδικό έγκρισης από τον διαχειριστή." 
                               FontSize="12" Foreground="#A0A0B0" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="2">
                        <TextBox Text="{Binding PasscodeInput, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="14" Padding="10,8,10,8" Background="#0F0F12" BorderBrush="#2B2B3C" 
                                 Foreground="#FFFFFF" CaretBrush="#6366F1" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="{Binding PasscodeError}" FontSize="11" Foreground="#EF4444" 
                               Margin="0,5,0,10" HorizontalAlignment="Center" TextWrapping="Wrap" 
                               Visibility="{Binding HasPasscodeError, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Ακύρωση" Style="{StaticResource OutlineButton}" Width="100" Margin="0,0,10,0" Command="{Binding CancelPasscodeCommand}"/>
                        <Button Content="Έγκριση" Style="{StaticResource PrimaryButton}" Width="120" Command="{Binding ConfirmPasscodeCommand}" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Admin Login Modal Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#A0000000" Visibility="{Binding IsAdminLoginModalOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="10" 
                    Width="380" Height="240" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title -->
                        <RowDefinition Height="Auto" /> <!-- Message -->
                        <RowDefinition Height="*" />    <!-- Input -->
                        <RowDefinition Height="Auto" /> <!-- Error -->
                        <RowDefinition Height="Auto" /> <!-- Actions -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔒 Είσοδος Διαχειριστή" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,8"/>
                    
                    <TextBlock Grid.Row="1" Text="Εισάγετε τον κωδικό διαχειριστή (clever2026) για να ξεκλειδώσετε τις ρυθμίσεις." 
                               FontSize="12" Foreground="#A0A0B0" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="2">
                        <TextBox Text="{Binding AdminPasscodeInput, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="14" Padding="10,8,10,8" Background="#0F0F12" BorderBrush="#2B2B3C" 
                                 Foreground="#FFFFFF" CaretBrush="#6366F1" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="{Binding AdminPasscodeError}" FontSize="11" Foreground="#EF4444" 
                               Margin="0,5,0,10" HorizontalAlignment="Center" TextWrapping="Wrap" 
                               Visibility="{Binding HasAdminPasscodeError, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Ακύρωση" Style="{StaticResource OutlineButton}" Width="100" Margin="0,0,10,0" Command="{Binding CancelAdminLoginCommand}"/>
                        <Button Content="Είσοδος" Style="{StaticResource PrimaryButton}" Width="120" Command="{Binding ConfirmAdminLoginCommand}" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Update Wizard Modal Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#A0000000" Visibility="{Binding IsWizardOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#16161F" BorderBrush="#2B2B3C" BorderThickness="1.5" CornerRadius="10" 
                    Width="500" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Header -->
                        <RowDefinition Height="*" />    <!-- Content depending on Stage -->
                        <RowDefinition Height="Auto" /> <!-- Footer Actions -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="{Binding WizardTitle}" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                        <TextBlock Text="{Binding WizardVersion, StringFormat='Έκδοση {0}'}" FontSize="12" Foreground="#6366F1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Content Stage 1: Welcome / Release Notes -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WizardStage}" Value="1">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="{Binding WizardDescription}" FontSize="13" Foreground="#E5E7EB" Margin="0,0,0,10" TextWrapping="Wrap"/>
                        
                        <Border Grid.Row="1" Background="#0F0F12" BorderBrush="#2B2B3C" BorderThickness="1" CornerRadius="6" Padding="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Σημειώσεις Έκδοσης:" FontSize="11" FontWeight="Bold" Foreground="#A0A0B0" Margin="0,0,0,5"/>
                                    <ItemsControl ItemsSource="{Binding WizardReleaseNotes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#D1D5DB" Margin="0,3,0,3" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Content Stage 2: Progress -->
                    <Grid Grid.Row="1" Margin="0,0,0,15" VerticalAlignment="Center">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WizardStage}" Value="2">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <StackPanel>
                            <TextBlock Text="Πρόοδος Εγκατάστασης..." FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <ProgressBar Height="15" Value="{Binding WizardProgress}" Minimum="0" Maximum="100" Margin="0,0,0,15">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                            <TextBlock Text="{Binding WizardStatus}" FontSize="12" Foreground="#A0A0B0" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Content Stage 3: Finish -->
                    <Grid Grid.Row="1" Margin="0,0,0,15" VerticalAlignment="Center">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WizardStage}" Value="3">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Success -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WizardSuccess}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="✔️" FontSize="48" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Η αναβάθμιση ολοκληρώθηκε!" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Η εφαρμογή ενημερώθηκε επιτυχώς στη νέα έκδοση." FontSize="13" Foreground="#A0A0B0" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <!-- Failure -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WizardSuccess}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="❌" FontSize="48" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Η αναβάθμιση απέτυχε" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding WizardErrorMessage}" FontSize="12" Foreground="#EF4444" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Footer Actions -->
                    <Border Grid.Row="2" BorderBrush="#2B2B3C" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                        <Grid>
                            <!-- Cancel (only visible in Stage 1) -->
                            <Button Content="Ακύρωση" HorizontalAlignment="Left" Width="100" Command="{Binding CancelWizardCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WizardStage}" Value="2">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WizardStage}" Value="3">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Next (Stage 1) / Finish (Stage 3) -->
                            <Button Width="120" HorizontalAlignment="Right" Command="{Binding NextWizardCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Content" Value="Επόμενο >"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WizardStage}" Value="2">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding WizardStage}" Value="3">
                                                <Setter Property="Content" Value="Τέλος"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

