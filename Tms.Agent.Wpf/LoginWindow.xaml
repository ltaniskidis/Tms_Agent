<Window x:Class="Tms.Agent.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TMS Agent - Σύνδεση" 
        Height="420" Width="360"
        Icon="logo.png"
        Background="#0F0F12"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif">

    <Window.Resources>
        <!-- Textbox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#16161F" />
            <Setter Property="BorderBrush" Value="#2B2B3C" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="10,8,10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Background" Value="#1C1C2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox Style -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#16161F" />
            <Setter Property="BorderBrush" Value="#2B2B3C" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="10,8,10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Background" Value="#1C1C2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#6366F1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10,16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4F46E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outline Button Style -->
        <Style TargetType="Button" x:Key="OutlineButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A0A0B0" />
            <Setter Property="BorderBrush" Value="#2B2B3C" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="10,6,10,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
            <TextBlock Text="🔒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="TMS AGENT LOGIN" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
            <TextBlock Text="Πληκτρολογήστε τα στοιχεία σας για είσοδο" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
            <StackPanel Margin="0,0,0,15">
                <!-- Error message -->
                <Border x:Name="ErrorBorder" Background="#2A1414" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Text="⚠️ Λανθασμένο όνομα ή κωδικός" Foreground="#FCA5A5" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </Border>

                <!-- Fields -->
                <StackPanel>
                    <TextBlock Text="ΟΝΟΜΑ ΧΡΗΣΤΗ" FontSize="10" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <TextBox x:Name="UsernameInput" Margin="0,0,0,15" Text="" KeyDown="Input_KeyDown"/>

                    <TextBlock Text="ΚΩΔΙΚΟΣ ΠΡΟΣΒΑΣΗΣ" FontSize="10" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Masked Password Input -->
                        <PasswordBox x:Name="PasswordInput" Grid.Column="0" KeyDown="Input_KeyDown"/>
                        
                        <!-- Plaintext Password Input -->
                        <TextBox x:Name="PasswordTextInput" Grid.Column="0" Visibility="Collapsed" KeyDown="Input_KeyDown"/>
                        
                        <!-- Toggle Button -->
                        <Button x:Name="TogglePasswordButton" Grid.Column="1" Content="👁️" 
                                Width="36" Height="34" Margin="5,0,0,0"
                                Style="{StaticResource OutlineButton}"
                                Click="TogglePasswordButton_Click" Focusable="False"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Submit Button -->
        <Button Grid.Row="2" TextBlock.FontSize="14" Content="Σύνδεση" Style="{StaticResource PrimaryButton}" Height="40" Click="LoginButton_Click"/>
    </Grid>
</Window>
